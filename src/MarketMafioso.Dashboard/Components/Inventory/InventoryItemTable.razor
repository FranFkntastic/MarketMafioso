<WebTableResizeSurface Columns="Columns"
                       StorageKey="@StorageKey"
                       ScrollClass="inventory-table-scroll"
                       AccentColor="var(--mmf-accent)"
                       BoundaryColor="var(--mmf-border)">
<table class="inventory-native-table items-table @(ShowCategory ? null : "without-category")" data-franthropy-resizable-table>
    <colgroup>
        @foreach (var column in Columns)
        {
            <col data-column-id="@column.Id"
                 data-default-width="@column.SafeDefaultWidthPx"
                 data-min-width="@column.SafeMinWidthPx"
                 style="width: @(column.SafeDefaultWidthPx)px" />
        }
    </colgroup>
    <thead>
        <tr class="inventory-column-row">
            <InventorySortHeader Label="Item" Column="item" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            @if (ShowCategory)
            {
                <InventorySortHeader Label="Category" Column="category" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            }
            <InventorySortHeader Label="Owned" Column="owned" Number="true" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            <InventorySortHeader Label="HQ" Column="hq" Number="true" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            <InventorySortHeader Label="Primary location" Column="location" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            <InventorySortHeader Label="Owners" Column="owners" Number="true" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
        </tr>
        <tr class="inventory-filter-row">
            <InventoryColumnFilter Label="Item" Column="item" Query="Query" FilterChanged="FilterChanged" />
            @if (ShowCategory)
            {
                <InventoryColumnFilter Label="Category" Column="category" Query="Query" FilterChanged="FilterChanged" />
            }
            <InventoryColumnFilter Label="Owned" Column="owned" Number="true" Query="Query" FilterChanged="FilterChanged" />
            <InventoryColumnFilter Label="HQ" Column="hq" Number="true" Query="Query" FilterChanged="FilterChanged" />
            <InventoryColumnFilter Label="Primary location" Column="location" Query="Query" FilterChanged="FilterChanged" />
            <InventoryColumnFilter Label="Owners" Column="owners" Number="true" Query="Query" FilterChanged="FilterChanged" />
        </tr>
    </thead>
    <tbody>
        <Virtualize TItem="InventoryBrowserItemView" Items="VirtualizedItems" Context="item" ItemSize="34" SpacerElement="tr">
            <tr class="@(SelectedItemId == item.ItemId ? "selected" : null)"
                role="button"
                tabindex="0"
                aria-label="@($"Inspect {item.DisplayName}")"
                aria-pressed="@(SelectedItemId == item.ItemId ? "true" : "false")"
                @onclick="@(() => ItemSelected.InvokeAsync(item))"
                @onkeydown="@(args => HandleKeyDownAsync(args, item))">
                <td><strong>@item.DisplayName</strong></td>
                @if (ShowCategory)
                {
                    <td>@(string.IsNullOrWhiteSpace(item.ItemType) ? "—" : item.ItemType)</td>
                }
                <td class="number">@item.TotalQuantity.ToString("N0")</td>
                <td class="number hq-value">@item.HqQuantity.ToString("N0")</td>
                <td>@InventoryDisplayFormatter.FormatItemLocations(item)</td>
                <td class="number">@item.OwnerCount.ToString("N0")</td>
            </tr>
        </Virtualize>
    </tbody>
</table>
</WebTableResizeSurface>

@code {
    private static readonly IReadOnlyList<WebTableResizeColumn> FullColumns =
    [
        new("item", "Item", 320, 140),
        new("category", "Category", 140, 90),
        new("owned", "Owned", 90, 64),
        new("hq", "HQ", 80, 56),
        new("location", "Primary location", 240, 130),
        new("owners", "Owners", 90, 64),
    ];

    private static readonly IReadOnlyList<WebTableResizeColumn> CompactColumns =
    [
        new("item", "Item", 340, 140),
        new("owned", "Owned", 100, 64),
        new("hq", "HQ", 90, 56),
        new("location", "Primary location", 330, 130),
        new("owners", "Owners", 100, 64),
    ];

    [Parameter] public IReadOnlyList<InventoryBrowserItemView> Items { get; set; } = [];
    [Parameter, EditorRequired] public InventoryTableQueryState Query { get; set; } = new();
    [Parameter] public bool ShowCategory { get; set; }
    [Parameter] public uint? SelectedItemId { get; set; }
    [Parameter] public EventCallback<InventoryBrowserItemView> ItemSelected { get; set; }
    [Parameter] public EventCallback<string> SortChanged { get; set; }
    [Parameter] public EventCallback<InventoryColumnFilterChange> FilterChanged { get; set; }
    private IReadOnlyList<WebTableResizeColumn> Columns => ShowCategory ? FullColumns : CompactColumns;
    private string StorageKey => $"mmf.inventory.column-widths.v2.items.{(ShowCategory ? "typed" : "compact")}";
    private ICollection<InventoryBrowserItemView> VirtualizedItems => Items as ICollection<InventoryBrowserItemView> ?? Items.ToArray();

    private Task HandleKeyDownAsync(KeyboardEventArgs args, InventoryBrowserItemView item) =>
        args.Key is "Enter" or " " ? ItemSelected.InvokeAsync(item) : Task.CompletedTask;
}
