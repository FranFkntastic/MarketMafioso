<WebTableResizeSurface Columns="Columns"
                       StorageKey="@StorageKey"
                       ScrollClass="inventory-table-scroll"
                       AccentColor="var(--mmf-accent)"
                       BoundaryColor="var(--mmf-border)">
<table class="inventory-native-table listings-table @(ShowPrices ? null : "without-prices")" data-franthropy-resizable-table>
    <colgroup>
        @foreach (var column in Columns)
        {
            <col data-column-id="@column.Id"
                 data-default-width="@column.SafeDefaultWidthPx"
                 data-min-width="@column.SafeMinWidthPx"
                 style="width: @(column.SafeDefaultWidthPx)px" />
        }
    </colgroup>
    <thead>
        <tr class="inventory-column-row">
            <InventorySortHeader Label="Item" Column="item" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            <InventorySortHeader Label="Retainer" Column="retainer" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            <InventorySortHeader Label="Qty" Column="quantity" Number="true" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            <InventorySortHeader Label="Quality" Column="quality" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            @if (ShowPrices)
            {
                <InventorySortHeader Label="Unit price" Column="unit-price" Number="true" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
                <InventorySortHeader Label="Total" Column="total" Number="true" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            }
            <InventorySortHeader Label="Observed" Column="observed" Number="true" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
        </tr>
        <tr class="inventory-filter-row">
            <InventoryColumnFilter Label="Item" Column="item" Query="Query" FilterChanged="FilterChanged" />
            <InventoryColumnFilter Label="Retainer" Column="retainer" Query="Query" FilterChanged="FilterChanged" />
            <InventoryColumnFilter Label="Qty" Column="quantity" Number="true" Query="Query" FilterChanged="FilterChanged" />
            <InventoryColumnFilter Label="Quality" Column="quality" Query="Query" FilterChanged="FilterChanged" />
            @if (ShowPrices)
            {
                <InventoryColumnFilter Label="Unit price" Column="unit-price" Number="true" Query="Query" FilterChanged="FilterChanged" />
                <InventoryColumnFilter Label="Total" Column="total" Number="true" Query="Query" FilterChanged="FilterChanged" />
            }
            <InventoryColumnFilter Label="Observed" Column="observed" Query="Query" FilterChanged="FilterChanged" />
        </tr>
    </thead>
    <tbody>
        <Virtualize TItem="InventoryBrowserMarketListingView" Items="VirtualizedListings" Context="listing" ItemSize="34" SpacerElement="tr">
            <tr>
                <td><strong>@listing.DisplayName</strong></td><td>@listing.OwnerName</td><td class="number">@listing.Quantity.ToString("N0")</td>
                <td><span class="quality-pill @(listing.HqQuantity > 0 ? "hq" : null)">@(listing.HqQuantity > 0 ? "HQ" : "NQ")</span></td>
                @if (ShowPrices)
                {
                    <td class="number price-value">@FormatUnitPrice(listing.UnitPrice)</td><td class="number">@FormatTotalPrice(listing.TotalPrice)</td>
                }
                <td class="number">@FormatAge(listing.EvidenceAgeSeconds)</td>
            </tr>
        </Virtualize>
    </tbody>
</table>
</WebTableResizeSurface>

@code {
    private static readonly IReadOnlyList<WebTableResizeColumn> PriceColumns =
    [
        new("item", "Item", 260, 140),
        new("retainer", "Retainer", 160, 100),
        new("quantity", "Qty", 80, 60),
        new("quality", "Quality", 80, 64),
        new("unit-price", "Unit price", 120, 90),
        new("total", "Total", 120, 90),
        new("observed", "Observed", 100, 76),
    ];

    private static readonly IReadOnlyList<WebTableResizeColumn> QuantityColumns =
    [
        new("item", "Item", 360, 140),
        new("retainer", "Retainer", 240, 100),
        new("quantity", "Qty", 110, 60),
        new("quality", "Quality", 110, 64),
        new("observed", "Observed", 120, 76),
    ];

    [Parameter] public IReadOnlyList<InventoryBrowserMarketListingView> Listings { get; set; } = [];
    [Parameter, EditorRequired] public InventoryTableQueryState Query { get; set; } = new();
    [Parameter] public bool ShowPrices { get; set; }
    [Parameter] public EventCallback<string> SortChanged { get; set; }
    [Parameter] public EventCallback<InventoryColumnFilterChange> FilterChanged { get; set; }
    private IReadOnlyList<WebTableResizeColumn> Columns => ShowPrices ? PriceColumns : QuantityColumns;
    private string StorageKey => $"mmf.inventory.column-widths.v2.listings.{(ShowPrices ? "priced" : "quantity")}";
    private ICollection<InventoryBrowserMarketListingView> VirtualizedListings => Listings as ICollection<InventoryBrowserMarketListingView> ?? Listings.ToArray();
    private static string FormatUnitPrice(uint? value) => value is null ? "Not recorded" : $"{value:N0} gil";
    private static string FormatTotalPrice(ulong? value) => value is null ? "Not recorded" : $"{value:N0} gil";
    private static string FormatAge(double? seconds) => seconds switch { null => "—", < 60 => "<1m", < 3600 => $"{seconds / 60:0}m", < 86400 => $"{seconds / 3600:0.#}h", _ => $"{seconds / 86400:0.#}d" };
}
