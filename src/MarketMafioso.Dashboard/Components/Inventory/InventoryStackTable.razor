<table class="inventory-native-table stacks-table" data-inventory-table="stacks">
    <thead>
        <tr class="inventory-column-row">
            <InventorySortHeader Label="Item" Column="item" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            <InventorySortHeader Label="Stored by" Column="owner" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            <InventorySortHeader Label="Storage" Column="storage" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            <InventorySortHeader Label="Qty" Column="quantity" Number="true" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            <InventorySortHeader Label="Quality" Column="quality" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
            <InventorySortHeader Label="Condition" Column="condition" Number="true" SortColumn="Query.SortColumn" Descending="Query.SortDescending" SortChanged="SortChanged" />
        </tr>
        <tr class="inventory-filter-row">
            <InventoryColumnFilter Label="Item" Column="item" Query="Query" FilterChanged="FilterChanged" />
            <InventoryColumnFilter Label="Stored by" Column="owner" Query="Query" FilterChanged="FilterChanged" />
            <InventoryColumnFilter Label="Storage" Column="storage" Query="Query" FilterChanged="FilterChanged" />
            <InventoryColumnFilter Label="Qty" Column="quantity" Number="true" Query="Query" FilterChanged="FilterChanged" />
            <InventoryColumnFilter Label="Quality" Column="quality" Query="Query" FilterChanged="FilterChanged" />
            <InventoryColumnFilter Label="Condition" Column="condition" Number="true" Query="Query" FilterChanged="FilterChanged" />
        </tr>
    </thead>
    <tbody>
        <Virtualize TItem="InventoryBrowserStackView" Items="VirtualizedStacks" Context="stack" ItemSize="34" SpacerElement="tr">
            <tr>
                <td><strong>@stack.DisplayName</strong></td>
                <td>@stack.OwnerName</td>
                <td>
                    <span>@InventoryDisplayFormatter.FormatStackStorage(stack)</span>
                    @if (stack.Equipped == true)
                    {
                        <span class="storage-pill equipped">Equipped</span>
                    }
                </td>
                <td class="number">@stack.Quantity.ToString("N0")</td>
                <td><span class="quality-pill @(stack.IsHq ? "hq" : null)">@(stack.IsHq ? "HQ" : "NQ")</span></td>
                <td class="number">@FormatPercent(stack.ConditionPercent)</td>
            </tr>
        </Virtualize>
    </tbody>
</table>

@code {
    [Parameter] public IReadOnlyList<InventoryBrowserStackView> Stacks { get; set; } = [];
    [Parameter, EditorRequired] public InventoryTableQueryState Query { get; set; } = new();
    [Parameter] public EventCallback<string> SortChanged { get; set; }
    [Parameter] public EventCallback<InventoryColumnFilterChange> FilterChanged { get; set; }
    private ICollection<InventoryBrowserStackView> VirtualizedStacks => Stacks as ICollection<InventoryBrowserStackView> ?? Stacks.ToArray();
    private static string FormatPercent(decimal? value) => value is null ? "—" : $"{value:0.#}%";
}
