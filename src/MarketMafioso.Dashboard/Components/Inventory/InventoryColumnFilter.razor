<th class="@(Number ? "number" : null)">
    <input value="@Query.Filter(Column)"
           @oninput="HandleInputAsync"
           inputmode="@(Number ? "decimal" : null)"
           aria-label="@($"Filter {Label}")"
           placeholder="Filter" />
</th>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter, EditorRequired] public string Column { get; set; } = string.Empty;
    [Parameter, EditorRequired] public InventoryTableQueryState Query { get; set; } = new();
    [Parameter] public bool Number { get; set; }
    [Parameter] public EventCallback<InventoryColumnFilterChange> FilterChanged { get; set; }

    private Task HandleInputAsync(ChangeEventArgs args) =>
        FilterChanged.InvokeAsync(new InventoryColumnFilterChange(Column, args.Value?.ToString() ?? string.Empty));
}
