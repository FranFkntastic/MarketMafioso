<label class="inventory-select-field">
    <span class="visually-hidden">Character</span>
    <select class="inventory-native-select"
            value="@CurrentValue"
            @onchange="HandleChangedAsync"
            aria-label="Character">
        <option value="">Latest available</option>
        @foreach (var group in Characters
            .GroupBy(character => character.ServiceAccountGroup)
            .OrderBy(group => GroupOrder(group.Key)))
        {
            <optgroup label="@group.Key">
                @foreach (var character in group.OrderBy(character => character.CharacterName, StringComparer.OrdinalIgnoreCase))
                {
                    <option value="@character.Id">@character.CharacterName</option>
                }
            </optgroup>
        }
    </select>
    @if (SelectedCharacter is { } selected)
    {
        <span class="inventory-character-context">@selected.HomeWorld · @selected.ServiceAccountGroup</span>
    }
</label>

@code {
    [Parameter] public IReadOnlyList<DashboardCharacterOption> Characters { get; set; } = [];
    [Parameter] public long? Value { get; set; }
    [Parameter] public EventCallback<long?> ValueChanged { get; set; }

    private string CurrentValue => Value?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
    private DashboardCharacterOption? SelectedCharacter => Value is { } id ? Characters.FirstOrDefault(character => character.Id == id) : null;
    private static int GroupOrder(string group) => group.StartsWith("Service Account ", StringComparison.Ordinal) ? 0 : 1;

    private Task HandleChangedAsync(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        return ValueChanged.InvokeAsync(long.TryParse(value, out var characterId) ? characterId : null);
    }
}
