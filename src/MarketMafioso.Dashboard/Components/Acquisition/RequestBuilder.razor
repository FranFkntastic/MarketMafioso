@using MarketMafioso.Dashboard.Models
@inject DashboardApiClient Api
@inject DashboardStatusService Status

<MudPaper Class="compact-card dashboard-panel builder-panel" Elevation="0">
    <div class="builder-shell">
        <header class="panel-heading">
            <h2>@BuilderTitle</h2>
            <span class="target-chip">@TargetDisplay</span>
        </header>

        <div class="builder-body">
            <div class="builder-scroll">
                <section class="builder-section">
                    <div class="section-label-row">
                        <h3>Target</h3>
                        <span>Where the plugin will pick this up</span>
                    </div>
                    <div class="input-grid">
                        <div class="field-block">
                            <div class="field-label-row">
                                <span>Character</span>
                                <span class="required-marker">Required</span>
                            </div>
                            <MudSelect T="long?" Value="_selectedCharacterId" ValueChanged="OnCharacterChanged" Placeholder="Choose character" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Disabled="@(IsEditMode || !Characters.Any())">
                                @foreach (var character in Characters)
                                {
                                    <MudSelectItem T="long?" Value="@character.Id">@character.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                            @if (IsEditMode)
                            {
                                <span class="muted field-note">Target is fixed: @EditTargetDisplay</span>
                            }
                            else if (SelectedCharacter is not null)
                            {
                                <span class="muted field-note">Home world: @SelectedCharacter.HomeWorld</span>
                            }
                        </div>

                        <div class="input-grid two-column">
                            <div class="field-block">
                                <div class="field-label-row"><span>Region</span></div>
                                <MudSelect T="string" Value="_region" ValueChanged="OnRegionChanged" Placeholder="Choose region" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                                    @foreach (var region in SupportedRegions)
                                    {
                                        <MudSelectItem Value="@region">@region</MudSelectItem>
                                    }
                                </MudSelect>
                            </div>
                            <div class="field-block">
                                <div class="field-label-row"><span>Routing</span></div>
                                <MudSelect T="string" @bind-Value="_worldMode" Placeholder="Choose routing" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                                    <MudSelectItem Value="@("Recommended")">Recommended worlds</MudSelectItem>
                                    <MudSelectItem Value="@("CurrentWorld")">Current world</MudSelectItem>
                                    <MudSelectItem Value="@("AllWorldSweep")">All-world sweep</MudSelectItem>
                                </MudSelect>
                            </div>
                        </div>
                        @if (IsAllWorldSweep)
                        {
                            <div class="field-block">
                                <div class="field-label-row help-label" title="Choose which worlds the sweep should explicitly visit and probe. Non-native regions are advanced route targets.">
                                    <span>Sweep scope</span>
                                </div>
                                <MudSelect T="string" @bind-Value="_sweepScope" Placeholder="Choose sweep scope" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                                    <MudSelectItem Value="@("Region")">Entire region</MudSelectItem>
                                    <MudSelectItem Value="@("CurrentDataCenter")">Current data center</MudSelectItem>
                                    <MudSelectItem Value="@("DataCenters")">Selected data centers</MudSelectItem>
                                </MudSelect>
                            </div>
                            @if (_sweepScope == "DataCenters")
                            {
                                <div class="sweep-dc-list">
                                    @foreach (var dataCenter in AvailableSweepDataCenters)
                                    {
                                        <label class="sweep-dc-option">
                                            <input type="checkbox"
                                                   checked="@_sweepDataCenters.Contains(dataCenter)"
                                                   @onchange="eventArgs => ToggleSweepDataCenter(dataCenter, eventArgs)" />
                                            <span>@dataCenter</span>
                                        </label>
                                    }
                                </div>
                            }
                        }
                    </div>
                    @if (!Characters.Any())
                    {
                        <span class="muted target-empty-hint">No characters are associated with this dashboard account yet. Send an inventory report with the configured API key first.</span>
                    }
                </section>

                <section class="builder-section item-section">
                    <div class="section-label-row">
                        <h3>Item</h3>
                        <span>Resolved before queueing</span>
                    </div>
                    <div class="field-block">
                        <div class="field-label-row">
                            <span>Item search</span>
                            <span class="required-marker">Required</span>
                        </div>
                        <MudAutocomplete T="XivItemSearchResult"
                                         Placeholder="Search by item name"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         FullWidth="true"
                                         Value="_selectedItem"
                                         ValueChanged="OnItemSelected"
                                         Text="@_itemSearchText"
                                         TextChanged="OnItemSearchTextChanged"
                                         SearchFunc="SearchItemsAsync"
                                         ToStringFunc="item => item?.ToString() ?? string.Empty"
                                         ResetValueOnEmptyText="true"
                                         CoerceText="false"
                                         Clearable="true"
                                         Dense="true"
                                         DebounceInterval="250" />
                    </div>
                </section>

                <section class="builder-section">
                    <div class="section-label-row">
                        <h3>Buy Rules</h3>
                        <span>Safety stops for live validation</span>
                    </div>
                    <div class="input-grid two-column">
                        <div class="field-block">
                            <div class="field-label-row help-label" title="@QuantityModeHelp"><span>Mode</span></div>
                            <MudSelect T="string" Value="@_quantityMode" ValueChanged="QuantityModeChanged" Placeholder="Choose quantity mode" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                                <MudSelectItem Value="@("TargetQuantity")">Target quantity</MudSelectItem>
                                <MudSelectItem Value="@("AllBelowThreshold")">All below threshold</MudSelectItem>
                            </MudSelect>
                        </div>
                        <div class="field-block">
                            <div class="field-label-row help-label" title="@QuantityHelp">
                                <span>@QuantityLabel</span>
                                <span class="optional-marker">@QuantityRequirementLabel</span>
                            </div>
                            <MudNumericField T="uint?" @bind-Value="_quantity" Placeholder="@QuantityLabel" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Min="0" />
                        </div>
                        <div class="field-block">
                            <div class="field-label-row help-label" title="Required safety threshold. The plugin skips live listings above this unit price.">
                                <span>Max unit price</span>
                                <span class="required-marker">Required</span>
                            </div>
                            <MudNumericField T="uint?" @bind-Value="_maxUnitPrice" Placeholder="Max unit price" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Min="1" />
                        </div>
                        <div class="field-block">
                            <div class="field-label-row help-label" title="Optional hard stop on total spend for this line. Leave blank to let max unit price govern buying.">
                                <span>Gil cap</span>
                                <span class="optional-marker">Optional</span>
                            </div>
                            <MudNumericField T="uint?" @bind-Value="_gilCap" Placeholder="Gil cap (optional)" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Min="0" />
                        </div>
                        <div class="field-block">
                            <div class="field-label-row"><span>HQ policy</span></div>
                            <MudSelect T="string" @bind-Value="_hqPolicy" Placeholder="Choose HQ policy" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                                <MudSelectItem Value="@("Either")">Either</MudSelectItem>
                                <MudSelectItem Value="@("NqOnly")">NQ only</MudSelectItem>
                                <MudSelectItem Value="@("HqOnly")">HQ only</MudSelectItem>
                            </MudSelect>
                        </div>
                        <div class="field-block durability-field">
                            <div class="field-label-row"><span>Inbox lifetime</span></div>
                            <div class="durability-value">Until completed or archived</div>
                        </div>
                    </div>
                </section>

                @if (_queue.Count > 0)
                {
                    <section class="builder-section local-queue-section">
                        <div class="section-label-row">
                            <h3>Draft Lines</h3>
                            <span>Not staged yet</span>
                        </div>
                        <MudTable Items="_queue" Dense="true" Hover="true" Class="queue-table local-queue-table">
                            <HeaderContent>
                                <MudTh>Item</MudTh>
                                <MudTh>Mode</MudTh>
                                <MudTh>Max Unit</MudTh>
                                <MudTh>Cap</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Item.Name<br /><span class="muted">Item @context.Item.ItemId</span></MudTd>
                                <MudTd>@context.QuantityModeDisplay<br /><span class="muted">@context.QuantityDisplay</span></MudTd>
                                <MudTd>@context.MaxUnitPrice.ToString("N0")</MudTd>
                                <MudTd>@context.GilCapDisplay</MudTd>
                                <MudTd><MudButton Size="Size.Small" OnClick="@(() => RemoveQueued(context))">Remove</MudButton></MudTd>
                            </RowTemplate>
                        </MudTable>
                    </section>
                }
            </div>

            <div class="composer-actions">
                <MudButton Variant="Variant.Outlined" Class="quiet-button" OnClick="ClearBuilder">Clear</MudButton>
                <span class="muted local-queue-count">@LocalQueueDisplay</span>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!CanAddRequest)" OnClick="AddToQueue">Add Line</MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="@(!CanAppendToPending)" OnClick="AppendToPendingAsync">@AppendButtonText</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="Busy || _queue.Count == 0" OnClick="SubmitQueueAsync">@SubmitButtonText</MudButton>
            </div>
        </div>
    </div>
</MudPaper>

@code {
    [Parameter] public bool Busy { get; set; }
    [Parameter] public Func<MarketAcquisitionBatchCreateRequest, Task<bool>>? StageRequested { get; set; }
    [Parameter] public Func<string, MarketAcquisitionBatchAppendLinesRequest, Task<bool>>? AppendRequested { get; set; }
    [Parameter] public Func<string, MarketAcquisitionBatchReplaceRequest, Task<bool>>? ReplaceRequested { get; set; }
    [Parameter] public IReadOnlyList<DashboardCharacterOption> Characters { get; set; } = [];
    [Parameter] public IReadOnlyList<MarketAcquisitionRequestView> PendingRequests { get; set; } = [];
    [Parameter] public DashboardSettingsView Settings { get; set; } = new();
    [Parameter] public MarketAcquisitionRequestView? PresetRequest { get; set; }
    [Parameter] public long PresetVersion { get; set; }
    [Parameter] public MarketAcquisitionRequestView? EditRequest { get; set; }
    [Parameter] public long EditVersion { get; set; }

    private long? _selectedCharacterId;
    private string _region = "North America";
    private string _worldMode = "Recommended";
    private XivItemSearchResult? _selectedItem;
    private string _itemSearchText = string.Empty;
    private string _quantityMode = "AllBelowThreshold";
    private string _sweepScope = "Region";
    private readonly HashSet<string> _sweepDataCenters = new(StringComparer.OrdinalIgnoreCase);
    private uint? _quantity;
    private uint? _maxUnitPrice;
    private uint? _gilCap;
    private string _hqPolicy = "Either";
    private int _expiresInMinutes = 5;
    private readonly List<QueuedAcquisitionItem> _queue = [];
    private bool _settingsApplied;
    private long _appliedPresetVersion;
    private long _appliedEditVersion;
    private string? _editRequestId;
    private int _editExpectedRevision;
    private string _editTargetCharacterName = string.Empty;
    private string _editTargetWorld = string.Empty;

    private DashboardCharacterOption? SelectedCharacter =>
        Characters.FirstOrDefault(character => character.Id == _selectedCharacterId);

    private bool IsEditMode => !string.IsNullOrWhiteSpace(_editRequestId);

    private string BuilderTitle => IsEditMode ? "Work Order Editor" : "Work Order Composer";

    private string EditTargetDisplay => string.IsNullOrWhiteSpace(_editTargetCharacterName)
        ? "Unknown target"
        : $"{_editTargetCharacterName} @ {_editTargetWorld}";

    private string TargetDisplay => IsEditMode
        ? EditTargetDisplay
        : SelectedCharacter?.DisplayName ?? "No character selected";

    private string QuantityLabel => _quantityMode == "AllBelowThreshold" ? "Max quantity (optional)" : "Target quantity";

    private string QuantityRequirementLabel => _quantityMode == "AllBelowThreshold" ? "Optional" : "Required";

    private string LocalQueueDisplay => _queue.Count == 0
        ? IsEditMode ? "No work-order lines" : "No draft lines"
        : _queue.Count == 1
            ? IsEditMode ? "1 work-order line" : "1 draft line"
            : IsEditMode ? $"{_queue.Count} work-order lines" : $"{_queue.Count} draft lines";

    private string StageButtonText => _queue.Count > 1 ? $"Publish {_queue.Count} Lines" : "Publish to Inbox";

    private string SubmitButtonText => IsEditMode ? "Update Work Order" : StageButtonText;

    private string AppendButtonText => _queue.Count == 0
        ? "Add to Existing"
        : CompatiblePendingBatches.Count switch
        {
            0 => "Add to Existing",
            1 => "Add to Existing",
            _ => "Choose via Inbox",
        };

    private bool CanAddRequest => (IsEditMode || SelectedCharacter is not null) && _selectedItem is not null && _maxUnitPrice is > 0;

    private bool CanAppendToPending =>
        !IsEditMode && !Busy && _queue.Count > 0 && AppendRequested is not null && CompatiblePendingBatches.Count == 1;

    private IReadOnlyList<MarketAcquisitionRequestView> CompatiblePendingBatches =>
        PendingRequests
            .Where(IsCompatiblePendingBatch)
            .ToArray();

    private bool IsAllWorldSweep => NormalizeWorldMode(_worldMode).Equals("AllWorldSweep", StringComparison.OrdinalIgnoreCase);

    private static readonly IReadOnlyDictionary<string, string[]> RegionDataCenters =
        new Dictionary<string, string[]>(StringComparer.OrdinalIgnoreCase)
        {
            ["North America"] = ["Aether", "Primal", "Crystal", "Dynamis"],
            ["Europe"] = ["Chaos", "Light"],
            ["Japan"] = ["Elemental", "Gaia", "Mana", "Meteor"],
            ["Oceania"] = ["Materia"],
        };

    private static IReadOnlyList<string> SupportedRegions { get; } = RegionDataCenters.Keys.ToArray();

    private IReadOnlyList<string> AvailableSweepDataCenters =>
        RegionDataCenters.TryGetValue(_region, out var dataCenters) ? dataCenters : [];

    private string QuantityModeHelp => _quantityMode == "AllBelowThreshold"
        ? "All below threshold buys every confirmed live listing at or below max unit price."
        : "Target quantity buys safe whole stacks until the target is satisfied.";

    private string QuantityHelp => _quantityMode == "AllBelowThreshold"
        ? "All below threshold buys every confirmed live listing at or below max unit price. Max quantity and gil cap are optional hard stops."
        : "Target quantity buys safe whole stacks until the target is satisfied; harmless overage can happen because stacks are indivisible.";

    protected override void OnParametersSet()
    {
        if (_settingsApplied)
        {
            ApplyIncomingRequestState();
            return;
        }

        _selectedCharacterId = Settings.DefaultCharacterId;
        if (_selectedCharacterId == null || Characters.All(character => character.Id != _selectedCharacterId))
            _selectedCharacterId = Characters.FirstOrDefault()?.Id;

        _region = NormalizeRegion(Settings.DefaultRegion);
        _worldMode = Settings.DefaultWorldMode;
        _expiresInMinutes = SecondsToMinutes(Settings.DefaultPickupExpiresSeconds);
        _settingsApplied = true;

        ApplyIncomingRequestState();
    }

    private void ApplyIncomingRequestState()
    {
        ApplyEditIfChanged();
        if (!IsEditMode)
            ApplyPresetIfChanged();
    }

    private void ApplyEditIfChanged()
    {
        if (EditRequest is null)
        {
            if (IsEditMode)
                ClearEditMode();
            _appliedEditVersion = EditVersion;
            return;
        }

        if (EditVersion == _appliedEditVersion)
            return;

        _appliedEditVersion = EditVersion;
        LoadRequestIntoBuilder(EditRequest, preserveCharacterSelection: false);
        _editRequestId = EditRequest.Id;
        _editExpectedRevision = EditRequest.Revision;
        _editTargetCharacterName = EditRequest.TargetCharacterName;
        _editTargetWorld = EditRequest.TargetWorld;
    }

    private void ApplyPresetIfChanged()
    {
        if (PresetRequest is null || PresetVersion == _appliedPresetVersion)
            return;

        _appliedPresetVersion = PresetVersion;
        ClearEditMode();
        LoadRequestIntoBuilder(PresetRequest, preserveCharacterSelection: true);
    }

    private void LoadRequestIntoBuilder(
        MarketAcquisitionRequestView request,
        bool preserveCharacterSelection)
    {
        var matchingCharacterId = Characters
            .FirstOrDefault(character =>
                string.Equals(character.CharacterName, request.TargetCharacterName, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(character.HomeWorld, request.TargetWorld, StringComparison.OrdinalIgnoreCase))
            ?.Id;
        _selectedCharacterId = matchingCharacterId ?? (preserveCharacterSelection ? _selectedCharacterId : null);
        _region = string.IsNullOrWhiteSpace(request.Region) ? _region : NormalizeRegion(request.Region);
        _worldMode = string.IsNullOrWhiteSpace(request.WorldMode) ? _worldMode : request.WorldMode;
        _sweepScope = string.IsNullOrWhiteSpace(request.SweepScope) ? "Region" : request.SweepScope;
        _sweepDataCenters.Clear();
        foreach (var dataCenter in request.SweepDataCenters)
            _sweepDataCenters.Add(dataCenter);

        var lines = MarketAcquisitionRequestDisplay.LinesFor(request);
        _queue.Clear();
        foreach (var line in lines)
        {
            _queue.Add(new QueuedAcquisitionItem
            {
                Item = new XivItemSearchResult
                {
                    ItemId = line.ItemId,
                    Name = MarketAcquisitionRequestDisplay.ItemLabel(line),
                    Type = line.ItemKind,
                },
                QuantityMode = string.IsNullOrWhiteSpace(line.QuantityMode) ? "AllBelowThreshold" : line.QuantityMode,
                Quantity = line.QuantityMode == "AllBelowThreshold" ? line.MaxQuantity : line.TargetQuantity,
                HqPolicy = string.IsNullOrWhiteSpace(line.HqPolicy) ? "Either" : line.HqPolicy,
                MaxUnitPrice = line.MaxUnitPrice,
                MaxTotalGil = line.GilCap,
                WorldMode = _worldMode,
            });
        }

        var firstLine = lines.FirstOrDefault();
        _selectedItem = firstLine is null
            ? null
            : new XivItemSearchResult
            {
                ItemId = firstLine.ItemId,
                Name = MarketAcquisitionRequestDisplay.ItemLabel(firstLine),
                Type = firstLine.ItemKind,
            };
        _itemSearchText = _selectedItem?.ToString() ?? string.Empty;
        _quantityMode = firstLine is null || string.IsNullOrWhiteSpace(firstLine.QuantityMode) ? "AllBelowThreshold" : firstLine.QuantityMode;
        _quantity = firstLine is null
            ? null
            : _quantityMode == "AllBelowThreshold"
                ? firstLine.MaxQuantity == 0 ? null : firstLine.MaxQuantity
                : firstLine.TargetQuantity == 0 ? null : firstLine.TargetQuantity;
        _hqPolicy = firstLine is null || string.IsNullOrWhiteSpace(firstLine.HqPolicy) ? "Either" : firstLine.HqPolicy;
        _maxUnitPrice = firstLine?.MaxUnitPrice is null or 0 ? null : firstLine.MaxUnitPrice;
        _gilCap = firstLine?.GilCap is null or 0 ? null : firstLine.GilCap;
    }

    private void ClearEditMode()
    {
        _editRequestId = null;
        _editExpectedRevision = 0;
        _editTargetCharacterName = string.Empty;
        _editTargetWorld = string.Empty;
    }

    private async Task<IEnumerable<XivItemSearchResult>> SearchItemsAsync(string value, CancellationToken token)
    {
        try
        {
            return await Api.SearchItemsAsync(value, token);
        }
        catch (OperationCanceledException)
        {
            return [];
        }
        catch (Exception ex)
        {
            Status.Error($"Item lookup failed: {ex.Message}");
            return [];
        }
    }

    private void OnItemSelected(XivItemSearchResult? item)
    {
        _selectedItem = item;
        if (item is not null)
            _itemSearchText = item.ToString();
    }

    private void OnItemSearchTextChanged(string value)
    {
        _itemSearchText = value;
        if (string.IsNullOrWhiteSpace(value))
            _selectedItem = null;
    }

    private void OnCharacterChanged(long? characterId)
    {
        _selectedCharacterId = characterId;
    }

    private void QuantityModeChanged(string mode)
    {
        _quantityMode = mode;
        if (mode == "AllBelowThreshold" && _quantity == 0)
            _quantity = null;
    }

    private void AddToQueue()
    {
        if (_selectedItem is null)
        {
            Status.Error("Pick an item before adding to the queue.");
            return;
        }

        if (!IsEditMode && SelectedCharacter is null)
        {
            Status.Error("Pick a dashboard character before adding to the queue.");
            return;
        }

        if (_maxUnitPrice is null or 0)
        {
            Status.Error("Max unit price is required.");
            return;
        }

        if (_quantityMode == "TargetQuantity" && (_quantity is null or 0))
        {
            Status.Error("Target quantity is required for TargetQuantity mode.");
            return;
        }

        _queue.Add(new QueuedAcquisitionItem
        {
            Item = _selectedItem,
            QuantityMode = _quantityMode,
            Quantity = _quantity ?? 0,
            HqPolicy = _hqPolicy,
            MaxUnitPrice = _maxUnitPrice.Value,
            MaxTotalGil = _gilCap ?? 0,
            WorldMode = _worldMode,
        });
        Status.Info($"Queued {_selectedItem.Name}.");
    }

    private Task SubmitQueueAsync() =>
        IsEditMode ? SaveEditAsync() : StageAsync();

    private async Task StageAsync()
    {
        if (StageRequested is null)
            return;

        if (SelectedCharacter is null)
        {
            Status.Error("Pick a dashboard character before staging the queue.");
            return;
        }

        if (!ValidateSweepSelection())
            return;

        var request = new MarketAcquisitionBatchCreateRequest
        {
            IdempotencyKey = Guid.NewGuid().ToString("N"),
            TargetCharacterName = SelectedCharacter.CharacterName,
            TargetWorld = SelectedCharacter.HomeWorld ?? string.Empty,
            Region = _region,
            WorldMode = NormalizeWorldMode(_worldMode),
            SweepScope = NormalizeSweepScope(),
            SweepDataCenters = ResolveSweepDataCenters(),
            ExpiresInSeconds = ExpirySeconds,
            Lines = _queue.Select(ToBatchLineRequest).ToArray(),
        };

        if (await StageRequested.Invoke(request))
            _queue.Clear();
    }

    private async Task SaveEditAsync()
    {
        if (ReplaceRequested is null || string.IsNullOrWhiteSpace(_editRequestId))
            return;

        if (!ValidateSweepSelection())
            return;

        var request = new MarketAcquisitionBatchReplaceRequest
        {
            ExpectedRevision = _editExpectedRevision,
            Region = _region,
            WorldMode = NormalizeWorldMode(_worldMode),
            SweepScope = NormalizeSweepScope(),
            SweepDataCenters = ResolveSweepDataCenters(),
            ExpiresInSeconds = ExpirySeconds,
            Lines = _queue.Select(ToBatchLineRequest).ToArray(),
        };

        await ReplaceRequested.Invoke(_editRequestId, request);
    }

    private async Task AppendToPendingAsync()
    {
        if (AppendRequested is null)
            return;

        var pendingBatch = CompatiblePendingBatches.SingleOrDefault();
        if (pendingBatch is null)
        {
            Status.Error("No compatible pending batch is available for this queue.");
            return;
        }

        var request = new MarketAcquisitionBatchAppendLinesRequest
        {
            ExpectedRevision = pendingBatch.Revision,
            ExpiresInSeconds = ExpirySeconds,
            Lines = _queue.Select(ToBatchLineRequest).ToArray(),
        };

        if (await AppendRequested.Invoke(pendingBatch.Id, request))
            _queue.Clear();
    }

    private bool ValidateSweepSelection()
    {
        if (IsAllWorldSweep && _sweepScope == "DataCenters" && _sweepDataCenters.Count == 0)
        {
            Status.Error("Pick at least one data center for a selected data-center sweep.");
            return false;
        }

        return true;
    }

    private int ExpirySeconds => Math.Clamp(_expiresInMinutes, 1, 1440) * 60;

    private static MarketAcquisitionBatchLineCreateRequest ToBatchLineRequest(QueuedAcquisitionItem item) => new()
    {
        ItemId = item.Item.ItemId,
        ItemName = item.Item.Name,
        ItemKind = item.Item.Type,
        QuantityMode = item.QuantityMode,
        TargetQuantity = item.QuantityMode == "TargetQuantity" ? item.Quantity : 0,
        MaxQuantity = item.QuantityMode == "AllBelowThreshold" ? item.Quantity : 0,
        HqPolicy = item.HqPolicy,
        MaxUnitPrice = item.MaxUnitPrice,
        GilCap = item.MaxTotalGil,
    };

    private static string NormalizeWorldMode(string value) =>
        value == "CurrentWorld" ? "CurrentWorldOnly" : value;

    private string NormalizeSweepScope() =>
        IsAllWorldSweep ? _sweepScope : "Region";

    private IReadOnlyList<string> ResolveSweepDataCenters() =>
        IsAllWorldSweep && _sweepScope == "DataCenters"
            ? AvailableSweepDataCenters.Where(dataCenter => _sweepDataCenters.Contains(dataCenter)).ToArray()
            : [];

    private bool IsCompatiblePendingBatch(MarketAcquisitionRequestView request)
    {
        if (SelectedCharacter is null || request.Status != "PendingPickup")
            return false;

        if (!string.Equals(request.TargetCharacterName, SelectedCharacter.CharacterName, StringComparison.OrdinalIgnoreCase) ||
            !string.Equals(request.TargetWorld, SelectedCharacter.HomeWorld, StringComparison.OrdinalIgnoreCase))
            return false;

        return string.Equals(NormalizeRegion(request.Region), _region, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(NormalizeWorldMode(request.WorldMode), NormalizeWorldMode(_worldMode), StringComparison.OrdinalIgnoreCase) &&
            string.Equals(request.SweepScope, NormalizeSweepScope(), StringComparison.OrdinalIgnoreCase) &&
            request.SweepDataCenters.Order(StringComparer.OrdinalIgnoreCase)
                .SequenceEqual(ResolveSweepDataCenters().Order(StringComparer.OrdinalIgnoreCase), StringComparer.OrdinalIgnoreCase);
    }

    private void OnRegionChanged(string region)
    {
        _region = NormalizeRegion(region);
        _sweepDataCenters.RemoveWhere(dataCenter => !AvailableSweepDataCenters.Contains(dataCenter, StringComparer.OrdinalIgnoreCase));
    }

    private static string NormalizeRegion(string region)
    {
        if (region.Equals("North-America", StringComparison.OrdinalIgnoreCase))
            return "North America";

        return RegionDataCenters.ContainsKey(region) ? region : "North America";
    }

    private void ToggleSweepDataCenter(string dataCenter, ChangeEventArgs args)
    {
        var selected = args.Value is bool value && value;
        if (selected)
            _sweepDataCenters.Add(dataCenter);
        else
            _sweepDataCenters.Remove(dataCenter);
    }

    private void RemoveQueued(QueuedAcquisitionItem item)
    {
        _queue.Remove(item);
    }

    private void ClearBuilder()
    {
        _selectedItem = null;
        _itemSearchText = string.Empty;
        _quantity = null;
        _maxUnitPrice = null;
        _gilCap = null;
        Status.Info("Builder cleared.");
    }

    private static int SecondsToMinutes(int seconds) =>
        Math.Clamp((int)Math.Ceiling(Math.Max(1, seconds) / 60d), 1, 1440);
}
