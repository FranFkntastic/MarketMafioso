@using MarketMafioso.Dashboard.Models

<MudPaper Class="compact-card dashboard-panel queue-panel" Elevation="0">
    <div class="queue-shell">
        <header class="panel-heading">
            <h2>Request Board</h2>
            <span class="target-chip">@ActiveRequestCount active</span>
        </header>

        <div class="queue-toolbar">
            <span class="status-pill @(LiveConnected ? "connected" : "disconnected")">
                <span class="status-dot"></span>
                <span>@LiveStatusText</span>
            </span>
            <span class="status-pill">@Requests.Count total request(s)</span>
            <div class="request-view-toggle">
                <MudButton Size="Size.Small"
                           Variant="@(!IncludeTerminal ? Variant.Filled : Variant.Outlined)"
                           Class="quiet-button"
                           OnClick="@(() => IncludeTerminalChanged.InvokeAsync(false))">Active</MudButton>
                <MudButton Size="Size.Small"
                           Variant="@(IncludeTerminal ? Variant.Filled : Variant.Outlined)"
                           Class="quiet-button"
                           OnClick="@(() => IncludeTerminalChanged.InvokeAsync(true))">Archive</MudButton>
            </div>
            <span class="toolbar-spacer"></span>
            <MudButton Variant="Variant.Outlined" Class="quiet-button" OnClick="RefreshRequested">Refresh</MudButton>
        </div>

        <div class="queue-body">
            @if (Requests.Count == 0)
            {
                <div class="request-empty-state">
                    <div>
                        <h3>@EmptyTitle</h3>
                        <p>@EmptyMessage</p>
                    </div>
                </div>
            }
            else
            {
                <MudDataGrid T="MarketAcquisitionRequestView"
                             Items="Requests"
                             Dense="true"
                             Hover="true"
                             FixedHeader="true"
                             ReadOnly="true"
                             SortMode="SortMode.Multiple"
                             Filterable="true"
                             ShowFilterIcons="true"
                             Class="queue-table operation-grid request-data-grid"
                             RowClassFunc="RowClass"
                             RowClick="@OnRowClicked">
                    <Columns>
                        <TemplateColumn Title="Item" Resizable="true">
                            <CellTemplate>
                                <div class="batch-cell">
                                    @if (MarketAcquisitionRequestDisplay.LinesFor(context.Item).Count > 1)
                                    {
                                        <div class="batch-title">@MarketAcquisitionRequestDisplay.TitleFor(context.Item)</div>
                                    }
                                    @foreach (var line in MarketAcquisitionRequestDisplay.LinesFor(context.Item))
                                    {
                                        <div class="batch-line">
                                            <span>@MarketAcquisitionRequestDisplay.ItemLabel(line)</span>
                                            <span class="muted">Item @line.ItemId</span>
                                        </div>
                                    }
                                    <span class="muted">@context.Item.TargetCharacterName @@ @context.Item.TargetWorld</span>
                                    <div>
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Color="@OriginColor(context.Item)"
                                                 Variant="Variant.Outlined">@OriginLabel(context.Item)</MudChip>
                                    </div>
                                </div>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Qty" Resizable="true">
                            <CellTemplate>
                                <div class="batch-cell compact">
                                    @foreach (var line in MarketAcquisitionRequestDisplay.LinesFor(context.Item))
                                    {
                                        <span>@MarketAcquisitionRequestDisplay.QuantityDisplay(line)</span>
                                    }
                                </div>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Max Unit" Resizable="true">
                            <CellTemplate>
                                <div class="batch-cell compact">
                                    @foreach (var line in MarketAcquisitionRequestDisplay.LinesFor(context.Item))
                                    {
                                        <span>@MarketAcquisitionRequestDisplay.MaxUnitDisplay(line)</span>
                                    }
                                </div>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Routing" Resizable="true">
                            <CellTemplate>@FormatRoute(context.Item)</CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Status" Resizable="true">
                            <CellTemplate>
                                <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Item.Status)">@context.Item.Status</MudChip>
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Latest" Resizable="true">
                            <CellTemplate>@FormatLatestRequestEvent(context.Item)</CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Actions" Resizable="true" Sortable="false" Filterable="false">
                            <CellTemplate>
                                <MudMenu Dense="true">
                                    <ActivatorContent>
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined">Actions</MudButton>
                                    </ActivatorContent>
                                    <ChildContent>
                                        @if (!IsTerminalRequest(context.Item))
                                        {
                                            <MudMenuItem OnClick="@(() => CancelRequested.InvokeAsync(context.Item.Id))">Cancel</MudMenuItem>
                                        }
                                        <MudMenuItem OnClick="@(() => ResendRequested.InvokeAsync(context.Item.Id))">Resend</MudMenuItem>
                                        <MudMenuItem OnClick="@(() => TemplateRequested.InvokeAsync(context.Item))">@TemplateActionText(context.Item)</MudMenuItem>
                                    </ChildContent>
                                </MudMenu>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                </MudDataGrid>
            }
        </div>
    </div>
</MudPaper>

@code {
    [Parameter] public IReadOnlyList<MarketAcquisitionRequestView> Requests { get; set; } = [];
    [Parameter] public MarketAcquisitionRequestView? SelectedRequest { get; set; }
    [Parameter] public EventCallback<MarketAcquisitionRequestView?> SelectedRequestChanged { get; set; }
    [Parameter] public bool LiveConnected { get; set; }
    [Parameter] public string LiveStatusText { get; set; } = "Live updates idle";
    [Parameter] public bool IncludeTerminal { get; set; }
    [Parameter] public EventCallback RefreshRequested { get; set; }
    [Parameter] public EventCallback<bool> IncludeTerminalChanged { get; set; }
    [Parameter] public EventCallback<string> CancelRequested { get; set; }
    [Parameter] public EventCallback<string> ResendRequested { get; set; }
    [Parameter] public EventCallback<MarketAcquisitionRequestView> TemplateRequested { get; set; }

    private int ActiveRequestCount => Requests.Count(IsActiveRequest);

    private string EmptyTitle => IncludeTerminal
        ? "No archived requests yet"
        : "No acquisition requests yet";

    private string EmptyMessage => IncludeTerminal
        ? "Completed, failed, cancelled, and rejected requests will appear here for inspection and reuse."
        : "Create a request on the left. Waiting and running requests will appear here.";

    private async Task OnRowClicked(DataGridRowClickEventArgs<MarketAcquisitionRequestView> args)
    {
        await SelectedRequestChanged.InvokeAsync(args.Item);
    }

    private string RowClass(MarketAcquisitionRequestView request, int rowNumber) =>
        SelectedRequest?.Id == request.Id ? "selected-grid-row" : string.Empty;

    private static Color StatusColor(string status) => status switch
    {
        "Complete" => Color.Success,
        "Failed" or "Cancelled" or "Rejected" => Color.Error,
        "Running" or "AcceptedInPlugin" => Color.Warning,
        _ => Color.Info,
    };

    private static string OriginLabel(MarketAcquisitionRequestView request) =>
        request.Origin.Equals(MarketAcquisitionOrigins.ClientQuickShop, StringComparison.OrdinalIgnoreCase)
            ? "Quick Shop"
            : "Dashboard";

    private static Color OriginColor(MarketAcquisitionRequestView request) =>
        request.Origin.Equals(MarketAcquisitionOrigins.ClientQuickShop, StringComparison.OrdinalIgnoreCase)
            ? Color.Secondary
            : Color.Default;

    private static bool IsActiveRequest(MarketAcquisitionRequestView request) =>
        !IsTerminalRequest(request);

    private static bool IsTerminalRequest(MarketAcquisitionRequestView request) =>
        request.Status is "Complete" or "Failed" or "Cancelled" or "Rejected" or "Expired";

    private static string TemplateActionText(MarketAcquisitionRequestView request) =>
        IsTerminalRequest(request) ? "Run again" : "Use as template";

    private static string FormatRoute(MarketAcquisitionRequestView request)
    {
        if (!request.WorldMode.Equals("AllWorldSweep", StringComparison.OrdinalIgnoreCase))
            return request.WorldMode;

        return request.SweepScope switch
        {
            "DataCenters" when request.SweepDataCenters.Count > 0 => $"Sweep: {string.Join(", ", request.SweepDataCenters)}",
            "CurrentDataCenter" => "Sweep: current DC",
            _ => "Sweep: region",
        };
    }

    private static string FormatLatestRequestEvent(MarketAcquisitionRequestView request)
    {
        if (!string.IsNullOrWhiteSpace(request.LatestAttemptId))
        {
            var world = string.IsNullOrWhiteSpace(request.LatestAttemptWorld)
                ? "route"
                : request.LatestAttemptWorld;
            var phase = string.IsNullOrWhiteSpace(request.LatestAttemptPhase)
                ? request.LatestAttemptEventType ?? "event"
                : request.LatestAttemptPhase;
            var result = string.IsNullOrWhiteSpace(request.LatestAttemptResult)
                ? string.Empty
                : $" / {request.LatestAttemptResult}";
            return $"{world}: {phase}{result}";
        }

        return request.LatestMessage ?? request.LatestReason ?? "-";
    }
}
