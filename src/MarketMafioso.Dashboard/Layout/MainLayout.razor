@inherits LayoutComponentBase
@inject DashboardThemeService ThemeService

<MudThemeProvider Theme="ThemeService.Theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Style="@ThemeService.RootStyle">
    <MudAppBar Elevation="0" Dense="true" Class="app-bar">
        <MudText Typo="Typo.h6" Class="brand">MarketMafioso</MudText>
        <MudText Typo="Typo.caption" Class="section-title">Dashboard</MudText>
        <MudSpacer />
        <div class="top-nav">
            <MudNavLink Href="" Match="NavLinkMatch.All" Class="top-nav-link">Acquisition</MudNavLink>
            <MudNavLink Href="inventory" Class="top-nav-link">Inventory</MudNavLink>
            <MudNavLink Href="overview" Class="top-nav-link">Overview</MudNavLink>
            <MudNavLink Href="settings" Class="top-nav-link">Settings</MudNavLink>
        </div>
    </MudAppBar>
    <MudMainContent Class="main-content">
        @Body
    </MudMainContent>
</MudLayout>
