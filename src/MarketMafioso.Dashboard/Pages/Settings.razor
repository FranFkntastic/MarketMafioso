@page "/settings"
@inject DashboardApiClient Api
@inject DashboardStatusService Status
@inject IJSRuntime JS
@inject IDialogService Dialog

<PageTitle>MarketMafioso Settings</PageTitle>

@if (_checkingSession)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_session is null)
{
    <DashboardLoginPanel LoggedIn="OnLoginSucceededAsync" />
}
else
{
<MudStack Spacing="2">
    <MudText Typo="Typo.h5">Settings</MudText>
    <DashboardStatusHost />
    <MudTabs Rounded="true" Elevation="0" PanelClass="pt-4">
        @if (_features.EnableMarketAcquisition)
        {
            <MudTabPanel Text="General">
                <MudPaper Class="compact-card" Elevation="0">
                    <MudStack Spacing="3" Class="settings-section">
                        <div>
                            <MudText Typo="Typo.h6">Dashboard Defaults</MudText>
                            <MudText Class="muted">Defaults apply to new acquisition requests on this dashboard account.</MudText>
                        </div>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="6">
                                <MudSelect T="long?" @bind-Value="_defaultCharacterId" Label="Default character" Variant="Variant.Outlined" Margin="Margin.Dense">
                                    <MudSelectItem T="long?" Value="@null">No default</MudSelectItem>
                                    @foreach (var character in _characters)
                                    {
                                        <MudSelectItem T="long?" Value="@character.Id">@character.DisplayName</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" @bind-Value="_defaultRegion" Label="Default region" Variant="Variant.Outlined" Margin="Margin.Dense">
                                    @foreach (var region in SupportedRegions)
                                    {
                                        <MudSelectItem Value="@region">@region</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="string" @bind-Value="_defaultWorldMode" Label="Default routing" Variant="Variant.Outlined" Margin="Margin.Dense">
                                    <MudSelectItem Value="@("Recommended")">Recommended worlds</MudSelectItem>
                                    <MudSelectItem Value="@("CurrentWorld")">Current world</MudSelectItem>
                                    <MudSelectItem Value="@("AllWorldSweep")">All-world sweep</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSelect T="int" @bind-Value="_defaultPickupExpiresSeconds" Label="Default pickup expiry" Variant="Variant.Outlined" Margin="Margin.Dense">
                                    <MudSelectItem Value="300">5 minutes</MudSelectItem>
                                    <MudSelectItem Value="900">15 minutes</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                        </MudGrid>
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_saving" OnClick="SaveSettingsAsync">Save Settings</MudButton>
                            <MudText Typo="Typo.caption" Class="muted">@_settingsStatus</MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudTabPanel>
        }
        <MudTabPanel Text="Diagnostics">
            <MudPaper Class="compact-card" Elevation="0">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">Diagnostics</MudText>
                    </MudStack>
                    <div class="settings-metric-grid">
                        <MetricTile Label="Stored Events" Value="@_storage.DiagnosticEventCount.ToString("N0")" />
                        <MetricTile Label="Retention Cap" Value="@_storage.DiagnosticEventRetentionCount.ToString("N0")" />
                        <MetricTile Label="Live Stream" Value="@SseLabel" />
                    </div>
                    <MudText Typo="Typo.caption" Class="muted">
                        @DiagnosticsStreamText
                    </MudText>
                    <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                        Route logs are currently stored by the plugin on the client machine. Server-side log indexing requires plugin upload of sanitized route summaries.
                    </MudAlert>
                    <DiagnosticsEventGrid Events="_events"
                                          RefreshRequested="LoadDiagnosticsAsync"
                                          SelectedEventChanged="SelectDiagnosticEvent" />
                    <DiagnosticEventDrawer Event="_selectedEvent"
                                           Closed="@(() => _selectedEvent = null)" />
                </MudStack>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="Snapshots">
            <MudPaper Class="compact-card" Elevation="0">
                <MudStack Spacing="2" Class="settings-section">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.h6">Snapshots</MudText>
                            <MudText Class="muted">Recent structured inventory snapshots visible to this dashboard account.</MudText>
                        </div>
                        <MudSpacer />
                        <MudButton Variant="Variant.Outlined" Class="quiet-button" OnClick="LoadSnapshotsAsync">Refresh</MudButton>
                    </MudStack>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="4">
                            <MudSelect T="long?" Value="_snapshotCharacterId" ValueChanged="OnSnapshotCharacterChanged" Label="Character filter" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem T="long?" Value="@null">All characters</MudSelectItem>
                                @foreach (var character in _characters)
                                {
                                    <MudSelectItem T="long?" Value="@character.Id">@character.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="8">
                            <div class="snapshot-retention-summary">
                                <MetricTile Label="Structured Snapshots" Value="@_storage.SnapshotCount.ToString("N0")" />
                                <MetricTile Label="Raw JSON Retained" Value="@_storage.RawJsonRetainedCount.ToString("N0")" />
                                <MetricTile Label="Raw JSON Pruned" Value="@_storage.RawJsonPrunedCount.ToString("N0")" />
                            </div>
                        </MudItem>
                        <MudItem xs="12">
                            <div class="snapshot-retention-summary wide">
                                <MetricTile Label="Structured Retention" Value="@($"{_storage.SnapshotRetentionCount:N0} snapshots")" />
                                <MetricTile Label="Raw JSON Retention" Value="@($"{_storage.RawJsonRetentionCount:N0} snapshots")" />
                                <MetricTile Label="Newest Snapshot" Value="@NewestSnapshotLabel" />
                                <MetricTile Label="Oldest Snapshot" Value="@OldestSnapshotLabel" />
                            </div>
                        </MudItem>
                    </MudGrid>
                    <MudDataGrid T="ReportSummaryView"
                                 Items="_snapshots"
                                 Dense="true"
                                 Hover="true"
                                 FixedHeader="true"
                                 ReadOnly="true"
                                 SortMode="SortMode.Multiple"
                                 Filterable="true"
                                 ShowFilterIcons="true"
                                 Class="queue-table snapshots-grid">
                        <Columns>
                            <TemplateColumn Title="Snapshot" Resizable="true">
                                <CellTemplate>
                                    @context.Item.Id<br />
                                    <span class="muted">@context.Item.ReceivedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") local</span>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Character" Resizable="true">
                                <CellTemplate>@($"{context.Item.CharacterName ?? "Unknown"} @ {context.Item.HomeWorld ?? "Unknown"}")</CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="snapshot => snapshot.PlayerItemStacks" Title="Player Stacks" Resizable="true" />
                            <PropertyColumn Property="snapshot => snapshot.RetainerCount" Title="Retainers" Resizable="true" />
                            <PropertyColumn Property="snapshot => snapshot.RetainerItemStacks" Title="Retainer Stacks" Resizable="true" />
                            <TemplateColumn Title="Quantity" Resizable="true">
                                <CellTemplate>@((context.Item.PlayerItemQuantity + context.Item.RetainerItemQuantity).ToString("N0"))</CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <NoRecordsContent>
                            <MudText Class="muted">No snapshots are available for this filter.</MudText>
                        </NoRecordsContent>
                    </MudDataGrid>
                    <MudText Typo="Typo.caption" Class="muted">@_snapshotStatus</MudText>
                </MudStack>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="Authentication">
            <MudStack Spacing="2">
                <MudPaper Class="compact-card" Elevation="0">
                    <MudStack Spacing="2" Class="settings-section">
                        <div>
                            <MudText Typo="Typo.h6">Client keys</MudText>
                            <MudText Class="muted">Issue a separate key for each client, then revoke it here without changing receiver configuration or restarting the server.</MudText>
                        </div>
                        <MudGrid Spacing="2">
                            <MudItem xs="12" md="5">
                                <MudTextField @bind-Value="_newClientKeyLabel"
                                              Label="Key label"
                                              Placeholder="Craft Architect on Firefox"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              MaxLength="80" />
                            </MudItem>
                            <MudItem xs="12" md="4">
                                <MudSelect T="string" @bind-Value="_newClientKeyPurpose" Label="Client" Variant="Variant.Outlined" Margin="Margin.Dense">
                                    <MudSelectItem Value="@("CraftArchitect")">Craft Architect</MudSelectItem>
                                    <MudSelectItem Value="@("MarketMafiosoClient")">MarketMafioso plugin</MudSelectItem>
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" md="3" Class="d-flex align-center">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           FullWidth="true"
                                           Disabled="@(_creatingClientKey || _createdClientKey is not null)"
                                           OnClick="CreateClientKeyAsync">
                                    Generate key
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                        <MudText Typo="Typo.caption" Class="muted">Craft Architect keys can only inspect capabilities and use the acquisition queue. Plugin keys retain full client compatibility.</MudText>
                    </MudStack>
                </MudPaper>

                @if (_createdClientKey is not null)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                        <MudStack Spacing="1">
                            <MudText><strong>Copy this key now.</strong> The receiver stores only its hash, so it cannot show the secret again.</MudText>
                            <MudTextField Value="_createdClientKey.Secret"
                                          ReadOnly="true"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          InputType="InputType.Password"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                                          OnAdornmentClick="CopyCreatedClientKeyAsync" />
                            <MudStack Row="true" AlignItems="AlignItems.Center">
                                <MudText Typo="Typo.caption">@_clientKeyCopyStatus</MudText>
                                <MudSpacer />
                                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="DismissCreatedClientKey">I've saved it</MudButton>
                            </MudStack>
                        </MudStack>
                    </MudAlert>
                }

                <MudPaper Class="compact-card" Elevation="0">
                    <MudDataGrid T="ClientCredentialView"
                                 Items="_clientKeys"
                                 Dense="true"
                                 Hover="true"
                                 ReadOnly="true"
                                 Class="queue-table">
                        <Columns>
                            <PropertyColumn Property="key => key.Label" Title="Label" />
                            <TemplateColumn Title="Client">
                                <CellTemplate>@ClientPurposeLabel(context.Item.Purpose)</CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Key">
                                <CellTemplate><code>@context.Item.KeyPrefix...</code></CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Last used">
                                <CellTemplate>@TimestampLabel(context.Item.LastUsedAtUtc)</CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Status">
                                <CellTemplate>
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="@(context.Item.RevokedAtUtc is null ? Color.Success : Color.Default)"
                                             Variant="Variant.Outlined">
                                        @(context.Item.RevokedAtUtc is null ? "Active" : "Revoked")
                                    </MudChip>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="">
                                <CellTemplate>
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               Disabled="@(context.Item.RevokedAtUtc is not null || _revokingClientKeyId == context.Item.Id)"
                                               OnClick="@(() => RevokeClientKeyAsync(context.Item.Id))">
                                        Revoke
                                    </MudButton>
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <NoRecordsContent>
                            <MudText Class="muted">No managed client keys yet. Environment-configured fallback keys are intentionally not shown here.</MudText>
                        </NoRecordsContent>
                    </MudDataGrid>
                </MudPaper>
            </MudStack>
        </MudTabPanel>
    </MudTabs>
</MudStack>
}

@code {
    private DashboardSessionResponse? _session;
    private IReadOnlyList<DiagnosticEventView> _events = [];
    private IReadOnlyList<DashboardCharacterOption> _characters = [];
    private IReadOnlyList<ReportSummaryView> _snapshots = [];
    private ReceiverStorageSummaryView _storage = new();
    private DashboardFeatureFlagsView _features = new();
    private DiagnosticEventView? _selectedEvent;
    private long? _defaultCharacterId;
    private long? _snapshotCharacterId;
    private string _defaultRegion = "North America";
    private string _defaultWorldMode = "Recommended";
    private int _defaultPickupExpiresSeconds = 300;
    private bool _checkingSession = true;
    private bool _saving;
    private string _settingsStatus = string.Empty;
    private string _snapshotStatus = string.Empty;
    private IReadOnlyList<ClientCredentialView> _clientKeys = [];
    private ClientCredentialCreatedView? _createdClientKey;
    private string _newClientKeyLabel = "Craft Architect";
    private string _newClientKeyPurpose = "CraftArchitect";
    private string _clientKeyCopyStatus = string.Empty;
    private bool _creatingClientKey;
    private long? _revokingClientKeyId;

    private static readonly string[] SupportedRegions =
    [
        "North America",
        "Europe",
        "Japan",
        "Oceania",
    ];

    private string NewestSnapshotLabel => _snapshots.Count == 0
        ? "-"
        : _snapshots.Max(snapshot => snapshot.ReceivedAt).ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private string OldestSnapshotLabel => _snapshots.Count == 0
        ? "-"
        : _snapshots.Min(snapshot => snapshot.ReceivedAt).ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private string SseLabel => _storage.AcquisitionSseCadenceSeconds <= 0
        ? "Configured"
        : $"{_storage.AcquisitionSseCadenceSeconds}s cadence";

    private string DiagnosticsStreamText => _features.EnableMarketAcquisition
        ? $"Acquisition and diagnostic snapshots stream through {_storage.AcquisitionSseEndpoint} every {_storage.AcquisitionSseCadenceSeconds} second(s)."
        : "Diagnostic snapshots are retained for receiver troubleshooting.";

    protected override async Task OnInitializedAsync()
    {
        _features = await Api.GetFeatureFlagsAsync();
        _session = await Api.GetSessionAsync();
        _checkingSession = false;
        if (_session is null)
            return;

        await LoadDashboardAsync();
    }

    private async Task OnLoginSucceededAsync(DashboardSessionResponse session)
    {
        _session = session;
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            await LoadSettingsAsync();
            await LoadStorageAsync();
            await LoadDiagnosticsAsync();
            if (_session is null)
                return;

            await LoadSnapshotsAsync();
            await LoadClientKeysAsync();
        }
        catch (DashboardUnauthorizedException)
        {
            ExpireSession();
        }
        catch (Exception ex)
        {
            Status.Error($"Settings load failed: {ex.Message}");
        }
    }

    private async Task LoadSettingsAsync()
    {
        _characters = await Api.GetCharactersAsync();
        var settings = await Api.GetDashboardSettingsAsync();
        _defaultCharacterId = settings.DefaultCharacterId;
        if (_defaultCharacterId != null && _characters.All(character => character.Id != _defaultCharacterId))
            _defaultCharacterId = null;
        _defaultRegion = NormalizeRegion(settings.DefaultRegion);
        _defaultWorldMode = settings.DefaultWorldMode;
        _defaultPickupExpiresSeconds = settings.DefaultPickupExpiresSeconds;
    }

    private static string NormalizeRegion(string region)
    {
        if (region.Equals("North-America", StringComparison.OrdinalIgnoreCase))
            return "North America";

        return SupportedRegions.Contains(region, StringComparer.OrdinalIgnoreCase) ? region : "North America";
    }

    private async Task SaveSettingsAsync()
    {
        try
        {
            _saving = true;
            var saved = await Api.SaveDashboardSettingsAsync(new DashboardSettingsUpdate
            {
                DefaultCharacterId = _defaultCharacterId,
                DefaultRegion = _defaultRegion,
                DefaultWorldMode = _defaultWorldMode,
                DefaultPickupExpiresSeconds = _defaultPickupExpiresSeconds,
            });
            _settingsStatus = saved.UpdatedAtUtc == null
                ? "Settings saved."
                : $"Settings saved {saved.UpdatedAtUtc.Value.ToLocalTime():HH:mm:ss}.";
        }
        catch (DashboardUnauthorizedException)
        {
            ExpireSession();
        }
        catch (Exception ex)
        {
            _settingsStatus = $"Save failed: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task LoadDiagnosticsAsync()
    {
        try
        {
            _events = await Api.GetDiagnosticsAsync();
            await LoadStorageAsync();
        }
        catch (DashboardUnauthorizedException)
        {
            ExpireSession();
        }
        catch (Exception ex)
        {
            Status.Error($"Diagnostics load failed: {ex.Message}");
        }
    }

    private async Task OnSnapshotCharacterChanged(long? value)
    {
        _snapshotCharacterId = value;
        await LoadSnapshotsAsync();
    }

    private async Task LoadSnapshotsAsync()
    {
        try
        {
            _snapshots = await Api.GetInventorySnapshotsAsync(_snapshotCharacterId);
            await LoadStorageAsync();
            _snapshotStatus = $"Loaded {_snapshots.Count:N0} snapshot(s).";
        }
        catch (DashboardUnauthorizedException)
        {
            ExpireSession();
        }
        catch (Exception ex)
        {
            _snapshotStatus = $"Snapshot load failed: {ex.Message}";
        }
    }

    private void SelectDiagnosticEvent(DiagnosticEventView item)
    {
        _selectedEvent = item;
    }

    private async Task LoadStorageAsync()
    {
        _storage = await Api.GetStorageSummaryAsync();
    }

    private async Task LoadClientKeysAsync()
    {
        _clientKeys = await Api.GetClientCredentialsAsync();
    }

    private async Task CreateClientKeyAsync()
    {
        if (string.IsNullOrWhiteSpace(_newClientKeyLabel))
        {
            Status.Error("Enter a label for the client key.");
            return;
        }

        try
        {
            _creatingClientKey = true;
            _createdClientKey = await Api.CreateClientCredentialAsync(new ClientCredentialCreateRequest
            {
                Label = _newClientKeyLabel.Trim(),
                Purpose = _newClientKeyPurpose,
            });
            _clientKeyCopyStatus = "Not copied yet.";
            await LoadClientKeysAsync();
        }
        catch (DashboardUnauthorizedException)
        {
            ExpireSession();
        }
        catch (Exception ex)
        {
            Status.Error($"Key generation failed: {ex.Message}");
        }
        finally
        {
            _creatingClientKey = false;
        }
    }

    private async Task CopyCreatedClientKeyAsync()
    {
        if (_createdClientKey is null)
            return;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _createdClientKey.Secret);
            _clientKeyCopyStatus = "Copied to clipboard.";
        }
        catch (JSException)
        {
            _clientKeyCopyStatus = "Clipboard access was blocked. Select and copy the key manually.";
        }
    }

    private void DismissCreatedClientKey()
    {
        _createdClientKey = null;
        _clientKeyCopyStatus = string.Empty;
    }

    private async Task RevokeClientKeyAsync(long id)
    {
        var key = _clientKeys.FirstOrDefault(candidate => candidate.Id == id);
        var confirmed = await Dialog.ShowMessageBox(
            "Revoke client key?",
            $"{key?.Label ?? "This client"} will stop connecting immediately. This cannot be undone.",
            yesText: "Revoke key",
            cancelText: "Keep key");
        if (confirmed != true)
            return;

        try
        {
            _revokingClientKeyId = id;
            await Api.RevokeClientCredentialAsync(id);
            if (_createdClientKey?.Id == id)
                _createdClientKey = null;
            await LoadClientKeysAsync();
        }
        catch (DashboardUnauthorizedException)
        {
            ExpireSession();
        }
        catch (Exception ex)
        {
            Status.Error($"Key revocation failed: {ex.Message}");
        }
        finally
        {
            _revokingClientKeyId = null;
        }
    }

    private static string ClientPurposeLabel(string purpose) => purpose switch
    {
        "CraftArchitect" => "Craft Architect",
        "MarketMafiosoClient" => "MarketMafioso plugin",
        _ => purpose,
    };

    private static string TimestampLabel(DateTimeOffset? timestamp) =>
        timestamp is null ? "Never" : timestamp.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private void ExpireSession()
    {
        _session = null;
        Status.Info("Dashboard session expired. Sign in again.");
    }
}
