@page "/inventory"
@inject DashboardApiClient Api
@inject DashboardStatusService Status
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>MarketMafioso Inventory</PageTitle>

@if (_checkingSession)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_session is null)
{
    <DashboardLoginPanel LoggedIn="OnLoginSucceededAsync" />
}
else
{
<MudStack Spacing="2" Class="dashboard-page inventory-page">
    <div class="inventory-titlebar">
        <MudText Typo="Typo.h5">Inventory</MudText>
        <MudText Typo="Typo.caption" Class="muted">@SnapshotLabel</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Outlined" Class="quiet-button" Disabled="_loading" OnClick="LoadInventoryAsync">Refresh</MudButton>
    </div>

    <DashboardStatusHost />

    <section class="inventory-shell">
        <aside class="inventory-scope-pane">
            <div class="inventory-character-select">
                <InventoryCharacterSelect Characters="_characters" Value="_selectedCharacterId" ValueChanged="OnCharacterChanged" />
            </div>
            <div class="inventory-scope-heading">Inventory scope</div>
            <div class="inventory-scope-list">
                <button class="@ScopeButtonClass("all")" @onclick="@(() => SetScopeAsync("all"))">
                    <span>Everything</span>
                    <strong>@_view.Scopes.Sum(scope => scope.StackCount).ToString("N0")</strong>
                    <small>Character and @_view.Scopes.Count(scope => scope.ScopeKey != "Player Inventory") retainers</small>
                </button>
                @foreach (var scope in _view.Scopes)
                {
                    <button class="@ScopeButtonClass(scope.ScopeKey)" @onclick="@(() => SetScopeAsync(scope.ScopeKey))">
                        <span>@scope.DisplayName</span>
                        <strong>@scope.StackCount.ToString("N0")</strong>
                        <small>@ScopeSummary(scope)</small>
                    </button>
                }
            </div>
            <div class="inventory-scope-footer">
                <strong>@CharacterLabel</strong>
                <span>@_view.Scopes.Sum(scope => scope.StackCount).ToString("N0") stacks · @GilSummary</span>
            </div>
        </aside>

        <div class="inventory-workspace">
            <div class="inventory-mobile-controls">
                <InventoryCharacterSelect Characters="_characters" Value="_selectedCharacterId" ValueChanged="OnCharacterChanged" />
                <InventoryScopeSelect Scopes="_view.Scopes" Value="_scope" ValueChanged="SetScopeAsync" />
            </div>
            <div class="inventory-filter-editor">
                <div class="inventory-commandbar">
                    <div class="inventory-mode-switch" role="group" aria-label="Inventory view">
                        @foreach (var mode in AvailableModes)
                        {
                            <button class="@ModeButtonClass(mode)"
                                    aria-pressed="@AriaBoolean(_mode == mode)"
                                    @onclick="@(() => SetModeAsync(mode))">@ModeLabel(mode)</button>
                        }
                    </div>
                    <WebFilterAutocomplete Value="_filterText"
                                           Items="_view.FilterCompletions"
                                           Edited="OnFilterEdited"
                                           ShowSuggestions="@(_showCompletions && !string.IsNullOrWhiteSpace(_filterText))"
                                           Placeholder="@FilterPlaceholder"
                                           AriaLabel="@FilterPlaceholder"
                                           SuggestionsLabel="Filter suggestions"
                                           MaximumItems="8"
                                           CssClass="inventory-filter" />
                    <MudTooltip Text="Filter reference">
                        <MudIconButton Icon="@Icons.Material.Filled.HelpOutline"
                                       Size="Size.Small"
                                       aria-label="Filter reference"
                                       OnClick="ToggleFilterReference" />
                    </MudTooltip>
                </div>

                @if (ShowFilterErrors)
                {
                    <div class="inventory-filter-error">
                        <div>
                            @foreach (var diagnostic in _view.FilterDiagnostics.Take(2))
                            {
                                <span>@diagnostic.Message</span>
                            }
                        </div>
                        @if (SuggestedFilterMode is { } suggestedMode)
                        {
                            <button @onclick="@(() => UseSuggestedModeAsync(suggestedMode))">Use in @ModeLabel(suggestedMode)</button>
                        }
                    </div>
                }
                @if (_showFilterReference)
                {
                    <div class="inventory-filter-reference">
                        <span><b>Names</b> search item names directly</span>
                        <span class="inventory-filter-fields"><b>Fields</b>
                            @foreach (var field in AvailableReferenceFields)
                            {
                                <code title="@ReferenceDetail(field)">@ReferenceLabel(field)</code>
                            }
                        </span>
                        <span><b>Logic</b> spaces mean AND; use OR, NOT, parentheses, and ranges such as 20..99</span>
                    </div>
                }
            </div>

            <div class="inventory-summary-strip">
                <div><strong>@_visibleMatchingRecordCount.ToString("N0")</strong><span>@RecordLabel(_mode)</span></div>
                <div><strong>@_visibleTotalQuantity.ToString("N0")</strong><span>total quantity</span></div>
                <div><strong>@_visibleHqQuantity.ToString("N0")</strong><span>HQ</span></div>
                <div><strong>@_visibleOwnerCount.ToString("N0")</strong><span>owners</span></div>
                @if (_mode == InventoryBrowserMode.Listings && _visibleMatchingRecordCount > 0)
                {
                    <div class="inventory-evidence-summary"><strong>@_visibleListingPriceKnownCount.ToString("N0")/@_visibleMatchingRecordCount.ToString("N0")</strong><span>with price evidence</span></div>
                }
            </div>

            @if (_mode == InventoryBrowserMode.Listings && _view.MatchingRecordCount > 0 && !HasListingPrices)
            {
                <div class="inventory-evidence-note">This snapshot records retainer listing quantities, but not their sale prices.</div>
            }

            <div class="inventory-content">
                <div class="inventory-table-host">
                    @if (_mode == InventoryBrowserMode.Items)
                    {
                        <InventoryGroupedTable Groups="_visibleInventoryGroups"
                                               Query="CurrentTableQuery"
                                               SortChanged="SortTable"
                                               FilterChanged="FilterTable" />
                    }
                    else
                    {
                        <InventoryListingTable Listings="_visibleListings" Query="CurrentTableQuery" ShowPrices="HasListingPrices" SortChanged="SortTable" FilterChanged="FilterTable" />
                    }

                    @if (_mode == InventoryBrowserMode.Listings && _view.FilterValid && _visibleMatchingRecordCount == 0)
                    {
                        <div class="inventory-empty">No matching @ModeLabel(_mode).ToLowerInvariant().</div>
                    }
                </div>

            </div>
        </div>
    </section>
</MudStack>
}

@code {
    private DashboardSessionResponse? _session;
    private IReadOnlyList<DashboardCharacterOption> _characters = [];
    private readonly Dictionary<InventoryBrowserMode, string> _filters = Enum.GetValues<InventoryBrowserMode>().ToDictionary(mode => mode, _ => string.Empty);
    private readonly Dictionary<InventoryBrowserMode, InventoryTableQueryState> _tableQueries = Enum.GetValues<InventoryBrowserMode>().ToDictionary(mode => mode, _ => new InventoryTableQueryState());
    private static readonly InventoryBrowserMode[] AvailableModes = [InventoryBrowserMode.Items, InventoryBrowserMode.Listings];
    private InventoryBrowserView _view = new();
    private InventoryBrowserView? _lastValidView;
    private long? _selectedCharacterId;
    private string _filterText = string.Empty;
    private string _scope = "all";
    private InventoryBrowserMode _mode = InventoryBrowserMode.Items;
    private bool _showFilterReference;
    private bool _showCompletions;
    private bool _checkingSession = true;
    private bool _loading;
    private CancellationTokenSource? _loadCts;
    private CancellationTokenSource? _filterDebounceCts;
    private int _filterCaret;
    private IReadOnlyList<InventoryGroupedItemRow> _visibleInventoryGroups = [];
    private IReadOnlyList<InventoryBrowserMarketListingView> _visibleListings = [];
    private int _visibleMatchingRecordCount;
    private int _visibleTotalQuantity;
    private int _visibleHqQuantity;
    private int _visibleOwnerCount;
    private int _visibleListingPriceKnownCount;

    private string SnapshotLabel => _view.ReceivedAt == null ? "No snapshot loaded" : $"{CharacterLabel} · captured {_view.ReceivedAt.Value.ToLocalTime():g}";
    private string CharacterLabel => string.IsNullOrWhiteSpace(_view.CharacterName) ? "No character selected" : $"{_view.CharacterName} @ {_view.HomeWorld}";
    private string FilterPlaceholder => $"Filter {ModeLabel(_mode).ToLowerInvariant()}…";
    private bool HasListingPrices => _view.ListingPriceKnownCount > 0;
    private InventoryTableQueryState CurrentTableQuery => _tableQueries[_mode];
    private string GilSummary => _view.PlayerGil is { } playerGil
        ? $"{playerGil:N0} gil"
        : _view.RetainerGil > 0
            ? $"{_view.RetainerGil:N0} retainer gil · wallet not recorded"
            : "Gil not recorded";
    private bool ShowFilterErrors => !_view.FilterValid && _view.FilterDiagnostics.Count > 0 && !InventoryFilterPresentation.IsIncomplete(_filterText);
    private InventoryBrowserMode? SuggestedFilterMode => ShowFilterErrors ? InventoryFilterPresentation.SuggestedMode(_filterText, _mode) : null;
    private IEnumerable<Franthropy.Filtering.Documentation.FilterFieldReference> AvailableReferenceFields =>
        _view.FilterReference?.Fields.Where(entry => entry.IsAvailable && !entry.IsDefaultText) ?? [];

    private static string ReferenceLabel(Franthropy.Filtering.Documentation.FilterFieldReference field) =>
        field.Aliases.OrderBy(alias => alias.Length).FirstOrDefault() ?? field.Key;

    private static string ReferenceDetail(Franthropy.Filtering.Documentation.FilterFieldReference field) =>
        $"{field.Description} Operators: {string.Join(", ", field.Operators)}";

    protected override async Task OnInitializedAsync()
    {
        RestoreUrlState();
        _session = await Api.GetSessionAsync();
        _checkingSession = false;
        if (_session is not null)
            await LoadInventoryContextAsync();
    }

    private async Task OnLoginSucceededAsync(DashboardSessionResponse session) { _session = session; await LoadInventoryContextAsync(); }

    private async Task LoadInventoryContextAsync()
    {
        try
        {
            _characters = await Api.GetCharactersAsync();
            var settings = await Api.GetDashboardSettingsAsync();
            _selectedCharacterId ??= settings.DefaultCharacterId;
            if (_selectedCharacterId is not null && _characters.All(character => character.Id != _selectedCharacterId))
                _selectedCharacterId = null;
            await LoadInventoryAsync();
        }
        catch (DashboardUnauthorizedException) { ExpireSession(); }
        catch (Exception ex) { Status.Error($"Inventory load failed: {ex.Message}"); }
    }

    private async Task OnCharacterChanged(long? value) { CancelFilterDebounce(); _selectedCharacterId = value; _scope = "all"; _lastValidView = null; await LoadInventoryAsync(); PersistUrlState(); }
    private Task OnFilterEdited(WebFilterAutocompleteEdit edit)
    {
        _filterText = edit.Value;
        _filterCaret = Math.Clamp(edit.CaretPosition, 0, _filterText.Length);
        _filters[_mode] = _filterText;
        _showCompletions = true;
        CancelFilterDebounce();

        if (edit.IsCompletion)
            return LoadFilterEditAsync();

        _filterDebounceCts = new CancellationTokenSource();
        _ = CompleteDebouncedFilterEditAsync(_filterDebounceCts.Token);
        return Task.CompletedTask;
    }
    private async Task SetScopeAsync(string scope) { CancelFilterDebounce(); _scope = string.IsNullOrWhiteSpace(scope) ? "all" : scope; _lastValidView = null; await LoadInventoryAsync(); PersistUrlState(); }
    private async Task SetModeAsync(InventoryBrowserMode mode) { if (_mode == mode) return; CancelFilterDebounce(); _filters[_mode] = _filterText; _mode = mode == InventoryBrowserMode.Stacks ? InventoryBrowserMode.Items : mode; _filterText = _filters[_mode]; _filterCaret = _filterText.Length; _lastValidView = null; _showFilterReference = false; _showCompletions = false; await LoadInventoryAsync(); PersistUrlState(); }
    private async Task UseSuggestedModeAsync(InventoryBrowserMode mode)
    {
        if (_mode == mode)
            return;

        CancelFilterDebounce();
        _filters[_mode] = _filterText;
        _mode = mode;
        _filters[mode] = _filterText;
        _filterCaret = _filterText.Length;
        _lastValidView = null;
        _showFilterReference = false;
        _showCompletions = false;
        await LoadInventoryAsync();
        PersistUrlState();
    }
    private void ToggleFilterReference() => _showFilterReference = !_showFilterReference;
    private void SortTable(string column) { CurrentTableQuery.ToggleSort(column); RebuildVisibleRows(); }
    private void FilterTable(InventoryColumnFilterChange change) { CurrentTableQuery.SetFilter(change.Column, change.Value); RebuildVisibleRows(); }

    private async Task CompleteDebouncedFilterEditAsync(CancellationToken token)
    {
        try
        {
            await Task.Delay(250, token);
            await InvokeAsync(LoadFilterEditAsync);
        }
        catch (OperationCanceledException) { }
    }

    private async Task LoadFilterEditAsync()
    {
        await LoadInventoryAsync();
        PersistUrlState();
    }

    private void CancelFilterDebounce()
    {
        _filterDebounceCts?.Cancel();
        _filterDebounceCts?.Dispose();
        _filterDebounceCts = null;
    }

    private async Task LoadInventoryAsync()
    {
        _loadCts?.Cancel(); _loadCts?.Dispose(); _loadCts = new CancellationTokenSource(); var token = _loadCts.Token;
        try
        {
            _loading = true;
            var response = await Api.GetInventoryBrowserAsync(
                _selectedCharacterId,
                _filterText,
                _scope,
                _mode,
                _filterCaret,
                token);
            if (response.FilterValid)
            {
                _view = response;
                _lastValidView = response;
            }
            else if (_lastValidView is { } last && last.Mode == response.Mode &&
                     last.Scope.Equals(response.Scope, StringComparison.OrdinalIgnoreCase) &&
                     last.SnapshotId == response.SnapshotId)
            {
                _view = response with
                {
                    Items = last.Items,
                    Stacks = last.Stacks,
                    MarketListings = last.MarketListings,
                    MatchingRecordCount = last.MatchingRecordCount,
                    TotalQuantity = last.TotalQuantity,
                    HqQuantity = last.HqQuantity,
                    OwnerCount = last.OwnerCount,
                    ItemTypeKnownCount = last.ItemTypeKnownCount,
                    ListingPriceKnownCount = last.ListingPriceKnownCount,
                };
            }
            else
            {
                _view = response;
            }
            RebuildVisibleRows();
        }
        catch (OperationCanceledException) { }
        catch (DashboardUnauthorizedException) { ExpireSession(); }
        catch (Exception ex) { Status.Error($"Inventory load failed: {ex.Message}"); }
        finally { if (!token.IsCancellationRequested) _loading = false; }
    }

    private void RestoreUrlState()
    {
        var values = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var segment in new Uri(Navigation.Uri).Query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var part = segment.Split('=', 2);
            values[Uri.UnescapeDataString(part[0])] = part.Length == 2 ? Uri.UnescapeDataString(part[1]) : string.Empty;
        }
        if (values.TryGetValue("mode", out var mode) && Enum.TryParse<InventoryBrowserMode>(mode, true, out var parsedMode))
            _mode = parsedMode == InventoryBrowserMode.Stacks ? InventoryBrowserMode.Items : parsedMode;
        if (values.TryGetValue("scope", out var scope) && !string.IsNullOrWhiteSpace(scope))
            _scope = scope;
        if (values.TryGetValue("filter", out var filter))
        {
            _filterText = filter;
            _filters[_mode] = filter;
            _filterCaret = filter.Length;
        }
        if (values.TryGetValue("characterId", out var characterId) && long.TryParse(characterId, out var parsedCharacterId))
            _selectedCharacterId = parsedCharacterId;
    }

    private void PersistUrlState()
    {
        Navigation.NavigateTo(
            InventoryNavigation.BuildPath(_mode, _scope, _filterText, _selectedCharacterId),
            replace: true);
    }

    private void ExpireSession() { _session = null; Status.Info("Dashboard session expired. Sign in again."); }
    private string ScopeButtonClass(string scope) => string.Equals(_scope, scope, StringComparison.OrdinalIgnoreCase) ? "inventory-scope active" : "inventory-scope";
    private string ModeButtonClass(InventoryBrowserMode mode) => _mode == mode ? "inventory-mode active" : "inventory-mode";
    private static string AriaBoolean(bool value) => value ? "true" : "false";
    private static string ModeLabel(InventoryBrowserMode mode) => mode == InventoryBrowserMode.Listings ? "Listings" : "Inventory";
    private static string RecordLabel(InventoryBrowserMode mode) => mode == InventoryBrowserMode.Listings ? "listings" : "items";

    private static string ScopeSummary(InventoryBrowserScopeView scope)
    {
        var parts = new List<string>();
        if (scope.Gil is > 0) parts.Add($"{scope.Gil:N0} gil");
        if (scope.MarketListingCount > 0) parts.Add($"{scope.MarketListingCount:N0} listings");
        return parts.Count == 0 ? scope.Description : string.Join(" · ", parts);
    }

    private void RebuildVisibleRows()
    {
        _visibleInventoryGroups = InventoryTableProjection.GroupedInventory(_view.Stacks, _tableQueries[InventoryBrowserMode.Items]);
        _visibleListings = InventoryTableProjection.Listings(_view.MarketListings, _tableQueries[InventoryBrowserMode.Listings]);

        switch (_mode)
        {
            case InventoryBrowserMode.Items:
                _visibleMatchingRecordCount = _visibleInventoryGroups.Count;
                _visibleTotalQuantity = checked((int)_visibleInventoryGroups.Sum(item => (long)item.TotalQuantity));
                _visibleHqQuantity = checked((int)_visibleInventoryGroups.Sum(item => (long)item.HqQuantity));
                _visibleOwnerCount = _visibleInventoryGroups.SelectMany(item => item.Stacks).Select(stack => stack.OwnerName).Distinct(StringComparer.OrdinalIgnoreCase).Count();
                _visibleListingPriceKnownCount = 0;
                break;
            default:
                _visibleMatchingRecordCount = _visibleListings.Count;
                _visibleTotalQuantity = checked((int)_visibleListings.Sum(listing => (long)listing.Quantity));
                _visibleHqQuantity = checked((int)_visibleListings.Sum(listing => (long)listing.HqQuantity));
                _visibleOwnerCount = _visibleListings.Select(listing => listing.OwnerName).Distinct(StringComparer.OrdinalIgnoreCase).Count();
                _visibleListingPriceKnownCount = _visibleListings.Count(listing => listing.UnitPrice is not null);
                break;
        }

    }

    public void Dispose() { CancelFilterDebounce(); _loadCts?.Cancel(); _loadCts?.Dispose(); }
}
