#!/bin/sh

old_rev="$1"
new_rev="$2"
is_branch_checkout="$3"

if [ "$is_branch_checkout" != "1" ]; then
    exit 0
fi

if [ "${MARKETMAFIOSO_SKIP_DEV_DEPLOY:-}" = "1" ]; then
    echo "Skipping MarketMafioso dev-plugin deploy because MARKETMAFIOSO_SKIP_DEV_DEPLOY=1."
    exit 0
fi

repo_root="$(git rev-parse --show-toplevel)" || exit 1
deploy_script="$repo_root/MarketMafioso/tools/Deploy-DevPlugin.ps1"

echo "Branch checkout detected ($old_rev -> $new_rev); deploying MarketMafioso dev plugin."
powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$deploy_script"
