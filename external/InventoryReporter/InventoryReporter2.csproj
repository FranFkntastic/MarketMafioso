<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <Version>1.0.0</Version>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <!-- DalamudPackager reads these from the csproj, not from manifest.json -->
    <Name>InventoryReporter</Name>
    <Author>Amamai</Author>
    <Description>Scans player inventory and retainers, sending snapshots to a remote server every 5 minutes.</Description>
    <Punchline>Automatically exports your inventory and retainer contents to your server.</Punchline>
    <RepoUrl>https://github.com/Alama1/InventoryReporter</RepoUrl>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Properties\manifest.json" />
  </ItemGroup>
</Project>