@page "/settings"
@inject DashboardApiClient Api

<PageTitle>MarketMafioso Settings</PageTitle>

<MudStack Spacing="2">
    <MudText Typo="Typo.h5">Settings</MudText>
    <MudTabs Rounded="true" Elevation="0" PanelClass="pt-4">
        <MudTabPanel Text="General">
            <MudPaper Class="compact-card" Elevation="0">
                <MudStack Spacing="3" Class="settings-section">
                    <div>
                        <MudText Typo="Typo.h6">Dashboard Defaults</MudText>
                        <MudText Class="muted">Defaults apply to new acquisition requests on this dashboard account.</MudText>
                    </div>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="6">
                            <MudSelect T="long?" @bind-Value="_defaultCharacterId" Label="Default character" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem T="long?" Value="@null">No default</MudSelectItem>
                                @foreach (var character in _characters)
                                {
                                    <MudSelectItem T="long?" Value="@character.Id">@character.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" @bind-Value="_defaultRegion" Label="Default region" Variant="Variant.Outlined" Margin="Margin.Dense">
                                @foreach (var region in SupportedRegions)
                                {
                                    <MudSelectItem Value="@region">@region</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" @bind-Value="_defaultWorldMode" Label="Default routing" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="@("Recommended")">Recommended worlds</MudSelectItem>
                                <MudSelectItem Value="@("CurrentWorld")">Current world</MudSelectItem>
                                <MudSelectItem Value="@("AllWorldSweep")">All-world sweep</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudSelect T="int" @bind-Value="_defaultPickupExpiresSeconds" Label="Default pickup expiry" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem Value="300">5 minutes</MudSelectItem>
                                <MudSelectItem Value="900">15 minutes</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_saving" OnClick="SaveSettingsAsync">Save Settings</MudButton>
                        <MudText Typo="Typo.caption" Class="muted">@_settingsStatus</MudText>
                    </MudStack>
                </MudStack>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="Diagnostics">
            <MudPaper Class="compact-card" Elevation="0">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudText Typo="Typo.h6">Diagnostics</MudText>
                    </MudStack>
                    <div class="settings-metric-grid">
                        <MetricTile Label="Stored Events" Value="@_storage.DiagnosticEventCount.ToString("N0")" />
                        <MetricTile Label="Retention Cap" Value="@_storage.DiagnosticEventRetentionCount.ToString("N0")" />
                        <MetricTile Label="Live Stream" Value="@SseLabel" />
                    </div>
                    <MudText Typo="Typo.caption" Class="muted">
                        Acquisition and diagnostic snapshots stream through @_storage.AcquisitionSseEndpoint every @_storage.AcquisitionSseCadenceSeconds second(s).
                    </MudText>
                    <DiagnosticsEventGrid Events="_events"
                                          RefreshRequested="LoadDiagnosticsAsync"
                                          SelectedEventChanged="SelectDiagnosticEvent" />
                    <DiagnosticEventDrawer Event="_selectedEvent"
                                           Closed="@(() => _selectedEvent = null)" />
                </MudStack>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="Snapshots">
            <MudPaper Class="compact-card" Elevation="0">
                <MudStack Spacing="2" Class="settings-section">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <div>
                            <MudText Typo="Typo.h6">Snapshots</MudText>
                            <MudText Class="muted">Recent structured inventory snapshots visible to this dashboard account.</MudText>
                        </div>
                        <MudSpacer />
                        <MudButton Variant="Variant.Outlined" Class="quiet-button" OnClick="LoadSnapshotsAsync">Refresh</MudButton>
                    </MudStack>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" md="4">
                            <MudSelect T="long?" Value="_snapshotCharacterId" ValueChanged="OnSnapshotCharacterChanged" Label="Character filter" Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem T="long?" Value="@null">All characters</MudSelectItem>
                                @foreach (var character in _characters)
                                {
                                    <MudSelectItem T="long?" Value="@character.Id">@character.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="8">
                            <div class="snapshot-retention-summary">
                                <MetricTile Label="Structured Snapshots" Value="@_storage.SnapshotCount.ToString("N0")" />
                                <MetricTile Label="Raw JSON Retained" Value="@_storage.RawJsonRetainedCount.ToString("N0")" />
                                <MetricTile Label="Raw JSON Pruned" Value="@_storage.RawJsonPrunedCount.ToString("N0")" />
                            </div>
                        </MudItem>
                        <MudItem xs="12">
                            <div class="snapshot-retention-summary wide">
                                <MetricTile Label="Structured Retention" Value="@($"{_storage.SnapshotRetentionCount:N0} snapshots")" />
                                <MetricTile Label="Raw JSON Retention" Value="@($"{_storage.RawJsonRetentionCount:N0} snapshots")" />
                                <MetricTile Label="Newest Snapshot" Value="@NewestSnapshotLabel" />
                                <MetricTile Label="Oldest Snapshot" Value="@OldestSnapshotLabel" />
                            </div>
                        </MudItem>
                    </MudGrid>
                    <MudDataGrid T="ReportSummaryView"
                                 Items="_snapshots"
                                 Dense="true"
                                 Hover="true"
                                 FixedHeader="true"
                                 ReadOnly="true"
                                 SortMode="SortMode.Multiple"
                                 Filterable="true"
                                 ShowFilterIcons="true"
                                 Class="queue-table snapshots-grid">
                        <Columns>
                            <TemplateColumn Title="Snapshot" Resizable="true">
                                <CellTemplate>
                                    @context.Item.Id<br />
                                    <span class="muted">@context.Item.ReceivedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") local</span>
                                </CellTemplate>
                            </TemplateColumn>
                            <TemplateColumn Title="Character" Resizable="true">
                                <CellTemplate>@($"{context.Item.CharacterName ?? "Unknown"} @ {context.Item.HomeWorld ?? "Unknown"}")</CellTemplate>
                            </TemplateColumn>
                            <PropertyColumn Property="snapshot => snapshot.PlayerItemStacks" Title="Player Stacks" Resizable="true" />
                            <PropertyColumn Property="snapshot => snapshot.RetainerCount" Title="Retainers" Resizable="true" />
                            <PropertyColumn Property="snapshot => snapshot.RetainerItemStacks" Title="Retainer Stacks" Resizable="true" />
                            <TemplateColumn Title="Quantity" Resizable="true">
                                <CellTemplate>@((context.Item.PlayerItemQuantity + context.Item.RetainerItemQuantity).ToString("N0"))</CellTemplate>
                            </TemplateColumn>
                        </Columns>
                        <NoRecordsContent>
                            <MudText Class="muted">No snapshots are available for this filter.</MudText>
                        </NoRecordsContent>
                    </MudDataGrid>
                    <MudText Typo="Typo.caption" Class="muted">@_snapshotStatus</MudText>
                </MudStack>
            </MudPaper>
        </MudTabPanel>
        <MudTabPanel Text="Authentication">
            <MudPaper Class="compact-card" Elevation="0">
                <MudText Typo="Typo.h6">Authentication</MudText>
                <MudText Class="muted">Dashboard sessions are cookie-backed. Plugin ingest and pickup still use the configured client API key.</MudText>
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
</MudStack>

@code {
    private IReadOnlyList<DiagnosticEventView> _events = [];
    private IReadOnlyList<DashboardCharacterOption> _characters = [];
    private IReadOnlyList<ReportSummaryView> _snapshots = [];
    private ReceiverStorageSummaryView _storage = new();
    private DiagnosticEventView? _selectedEvent;
    private long? _defaultCharacterId;
    private long? _snapshotCharacterId;
    private string _defaultRegion = "North America";
    private string _defaultWorldMode = "Recommended";
    private int _defaultPickupExpiresSeconds = 300;
    private bool _saving;
    private string _settingsStatus = string.Empty;
    private string _snapshotStatus = string.Empty;

    private static readonly string[] SupportedRegions =
    [
        "North America",
        "Europe",
        "Japan",
        "Oceania",
    ];

    private string NewestSnapshotLabel => _snapshots.Count == 0
        ? "-"
        : _snapshots.Max(snapshot => snapshot.ReceivedAt).ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private string OldestSnapshotLabel => _snapshots.Count == 0
        ? "-"
        : _snapshots.Min(snapshot => snapshot.ReceivedAt).ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private string SseLabel => _storage.AcquisitionSseCadenceSeconds <= 0
        ? "Configured"
        : $"{_storage.AcquisitionSseCadenceSeconds}s cadence";

    protected override async Task OnInitializedAsync()
    {
        await LoadSettingsAsync();
        await LoadStorageAsync();
        await LoadDiagnosticsAsync();
        await LoadSnapshotsAsync();
    }

    private async Task LoadSettingsAsync()
    {
        _characters = await Api.GetCharactersAsync();
        var settings = await Api.GetDashboardSettingsAsync();
        _defaultCharacterId = settings.DefaultCharacterId;
        if (_defaultCharacterId != null && _characters.All(character => character.Id != _defaultCharacterId))
            _defaultCharacterId = null;
        _defaultRegion = NormalizeRegion(settings.DefaultRegion);
        _defaultWorldMode = settings.DefaultWorldMode;
        _defaultPickupExpiresSeconds = settings.DefaultPickupExpiresSeconds;
    }

    private static string NormalizeRegion(string region)
    {
        if (region.Equals("North-America", StringComparison.OrdinalIgnoreCase))
            return "North America";

        return SupportedRegions.Contains(region, StringComparer.OrdinalIgnoreCase) ? region : "North America";
    }

    private async Task SaveSettingsAsync()
    {
        try
        {
            _saving = true;
            var saved = await Api.SaveDashboardSettingsAsync(new DashboardSettingsUpdate
            {
                DefaultCharacterId = _defaultCharacterId,
                DefaultRegion = _defaultRegion,
                DefaultWorldMode = _defaultWorldMode,
                DefaultPickupExpiresSeconds = _defaultPickupExpiresSeconds,
            });
            _settingsStatus = saved.UpdatedAtUtc == null
                ? "Settings saved."
                : $"Settings saved {saved.UpdatedAtUtc.Value.ToLocalTime():HH:mm:ss}.";
        }
        catch (Exception ex)
        {
            _settingsStatus = $"Save failed: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task LoadDiagnosticsAsync()
    {
        _events = await Api.GetDiagnosticsAsync();
        await LoadStorageAsync();
    }

    private async Task OnSnapshotCharacterChanged(long? value)
    {
        _snapshotCharacterId = value;
        await LoadSnapshotsAsync();
    }

    private async Task LoadSnapshotsAsync()
    {
        try
        {
            _snapshots = await Api.GetInventorySnapshotsAsync(_snapshotCharacterId);
            await LoadStorageAsync();
            _snapshotStatus = $"Loaded {_snapshots.Count:N0} snapshot(s).";
        }
        catch (Exception ex)
        {
            _snapshotStatus = $"Snapshot load failed: {ex.Message}";
        }
    }

    private void SelectDiagnosticEvent(DiagnosticEventView item)
    {
        _selectedEvent = item;
    }

    private async Task LoadStorageAsync()
    {
        _storage = await Api.GetStorageSummaryAsync();
    }
}
