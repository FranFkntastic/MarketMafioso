@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Class="app-bar">
        <MudText Typo="Typo.h6" Class="brand">MarketMafioso</MudText>
        <MudText Typo="Typo.caption" Class="section-title">Dashboard</MudText>
        <MudSpacer />
        <div class="top-nav">
            <MudNavLink Href="" Match="NavLinkMatch.All" Class="top-nav-link">Acquisition</MudNavLink>
            <MudNavLink Href="inventory" Class="top-nav-link">Inventory</MudNavLink>
            <MudNavLink Href="overview" Class="top-nav-link">Overview</MudNavLink>
            <MudNavLink Href="settings" Class="top-nav-link">Settings</MudNavLink>
        </div>
    </MudAppBar>
    <MudMainContent Class="main-content">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#5aa8ff",
            Secondary = "#8bd6a3",
            Surface = "#121920",
            Background = "#090e13",
            BackgroundGray = "#0f151b",
            AppbarBackground = "#101720",
            AppbarText = "#f4f8ff",
            DrawerBackground = "#111821",
            TextPrimary = "#f4f8ff",
            TextSecondary = "#a8bed8",
            LinesDefault = "#273646",
            TableLines = "#273646",
            TableStriped = "#111a22",
            ActionDefault = "#a8bed8",
            ActionDisabled = "#637080",
            Error = "#ff6b7a",
            Info = "#5aa8ff",
            Success = "#3ddc84",
            Warning = "#f8c14a",
        },
    };
}
